@model MedicalApp.Areas.CAM.Models.CamBatchProgressPageViewModel
@{
    ViewData["Title"] = "Progres lot — " + Model.ClinicName;
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
        <h2 class="text-primary fw-bold mb-0" data-testid="cam-batch-progress-heading">
            &#9203; Lot în execuție
        </h2>
        <span class="badge bg-secondary" data-testid="cam-batch-id">#@Model.BatchRunId</span>
        <span class="text-muted small ms-2">
            Pornit: @Model.StartedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")
        </span>
        <div class="ms-auto">
            <a asp-controller="Dashboard" asp-action="Index" asp-area="CAM"
               class="btn btn-outline-secondary btn-sm" data-testid="cam-back-dashboard">
                &larr; Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-info" data-testid="cam-batch-progress-flash">@TempData["SuccessMessage"]</div>
    }

    <div class="card mb-3 border-primary">
        <div class="card-body">
            <div class="d-flex align-items-center flex-wrap gap-3 mb-2">
                <div>
                    <div class="small text-muted">Fișiere selectate</div>
                    <div class="display-5 fw-bold text-primary" id="prgTotal" data-testid="cam-progress-total">0</div>
                </div>
                <div class="vr d-none d-md-block" style="height: 60px;"></div>
                <div>
                    <div class="small text-muted">Procesate până acum</div>
                    <div class="display-6 fw-semibold" id="prgProcessed" data-testid="cam-progress-processed">0</div>
                </div>
                <div class="ms-auto text-end">
                    <div class="badge bg-info-subtle text-info-emphasis fs-6 px-3 py-2"
                         id="prgWaitMsg" data-testid="cam-progress-wait-msg">
                        &#9203; Așteptați câteva secunde…
                    </div>
                    <div class="small text-muted mt-1">
                        Interpretarea AI durează ~2-3 min/fișier.
                    </div>
                </div>
            </div>
            <div class="text-muted small">
                Fișier curent: <code id="prgCurrent" data-testid="cam-progress-current">—</code>
            </div>

            <!-- Mascotă doctoraș (state machine driven de polling) -->
            @{
                var camProgressMascotVd = new ViewDataDictionary(ViewData)
                {
                    ["Mode"] = "progress",
                    ["Size"] = "medium",
                    ["StageId"] = "camProgressMascot",
                    ["TestId"] = "cam-progress-doc-stage"
                };
            }
            <partial name="_DoctorMascot" view-data="camProgressMascotVd" />
        </div>
    </div>

    <div class="row g-2 mb-3" data-testid="cam-progress-counters">
        <div class="col-md-3">
            <div class="card border-success"><div class="card-body py-2 text-center">
                <div class="small text-muted">Trimise</div>
                <div class="fs-3 fw-bold text-success" id="prgSent">0</div>
            </div></div>
        </div>
        <div class="col-md-3">
            <div class="card border-info"><div class="card-body py-2 text-center">
                <div class="small text-muted">Comparate</div>
                <div class="fs-3 fw-bold text-info" id="prgCompared">0</div>
            </div></div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning"><div class="card-body py-2 text-center">
                <div class="small text-muted">NotSends</div>
                <div class="fs-3 fw-bold text-warning" id="prgNotSends">0</div>
            </div></div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary"><div class="card-body py-2 text-center">
                <div class="small text-muted">Status</div>
                <div class="fs-5 fw-bold" id="prgStatus" data-testid="cam-progress-status">Running</div>
            </div></div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-bold">Log live</div>
        <div class="card-body p-0">
            <pre id="prgLog" data-testid="cam-progress-log"
                 style="max-height:340px;overflow:auto;margin:0;padding:14px;background:#0d1117;color:#c9d1d9;font-size:12px;line-height:1.6;">Aștept primul mesaj…</pre>
        </div>
    </div>

    <div class="d-flex gap-2" id="actionsContainer">
        <form asp-action="Cancel" asp-route-id="@Model.BatchRunId" method="post"
              id="cancelForm" data-testid="cam-batch-cancel-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger fw-bold" id="cancelBtn"
                    data-testid="cam-batch-cancel-submit">
                &#9209; Anulează lotul
            </button>
        </form>
        <a asp-action="Start" class="btn btn-outline-primary d-none" id="newBatchBtn"
           data-testid="cam-batch-new-link">
            &#128229; Lansează un lot nou
        </a>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var batchId = @Model.BatchRunId;
    // Build the Status URL via Razor's URL helper so it survives changes to
    // PathBase (e.g. when the app is mounted under a virtual sub-application
    // in IIS). A hardcoded "/CAM/Batch/Status/..." would 404 in that case
    // and silently leave the live UI stuck on "0 / 0 fișiere".
    var statusUrl = '@Url.Action("Status", "Batch", new { area = "CAM", id = "__BID__" })'
                        .replace('__BID__', batchId);
    var pollMs = 3000;
    var pollTimer = null;

    // Mascota e instanțiată automat la DOMContentLoaded de doctor-mascot.js.
    // O preluăm aici prin API-ul global.
    var mascot = window.DoctorMascot && window.DoctorMascot.get('camProgressMascot');

    function render(data) {
        document.getElementById('prgProcessed').textContent = data.processed;
        document.getElementById('prgTotal').textContent = data.total;
        document.getElementById('prgSent').textContent = data.sent;
        document.getElementById('prgCompared').textContent = data.compared;
        document.getElementById('prgNotSends').textContent = data.notSends;
        document.getElementById('prgCurrent').textContent = data.currentFile || '—';

        var statusEl = document.getElementById('prgStatus');
        statusEl.textContent = data.status;
        statusEl.className = 'fs-5 fw-bold ' +
            (data.status === 'Running'   ? 'text-primary'
            : data.status === 'Completed' ? 'text-success'
            : data.status === 'Cancelled' ? 'text-warning'
            : 'text-danger');

        if ((data.log || []).length > 0) {
            document.getElementById('prgLog').textContent = data.log.join('\n');
            var logEl = document.getElementById('prgLog');
            logEl.scrollTop = logEl.scrollHeight;
        }

        if (data.finished) {
            // Swap the "Așteptați…" message for a clear completion badge,
            // hide Cancel, show "Lansează lot nou".
            var waitMsg = document.getElementById('prgWaitMsg');
            if (data.status === 'Completed') {
                waitMsg.className = 'badge bg-success fs-6 px-3 py-2';
                waitMsg.textContent = '✓ Procesare finalizată';
            } else if (data.status === 'Cancelled') {
                waitMsg.className = 'badge bg-warning text-dark fs-6 px-3 py-2';
                waitMsg.textContent = '⏹ Anulat';
            } else {
                waitMsg.className = 'badge bg-danger fs-6 px-3 py-2';
                waitMsg.textContent = '✘ Eșuat';
            }
            document.getElementById('cancelForm').classList.add('d-none');
            document.getElementById('newBatchBtn').classList.remove('d-none');
            if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
        }

        // Update mascotă pe baza progresului (state machine în doctor-mascot.js)
        if (mascot) {
            mascot.onProgress(data.processed, data.total, data.finished, data.status);
        }
    }

    function poll() {
        // Cache-busting query param + cache: 'no-store' on the request side
        // belt-and-suspenders with the Cache-Control: no-store headers the
        // server sets — some intermediaries respect one but not the other.
        var url = statusUrl + '?t=' + Date.now();
        fetch(url, { credentials: 'same-origin', cache: 'no-store' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(d) { if (d) render(d); })
            .catch(function() { /* keep polling on transient errors */ });
    }

    // Așteptăm puțin ca să fie sigur că mascota a fost inițializată (DOMContentLoaded)
    if (!mascot) {
        document.addEventListener('DOMContentLoaded', function() {
            mascot = window.DoctorMascot && window.DoctorMascot.get('camProgressMascot');
        });
    }

    poll();
    pollTimer = setInterval(poll, pollMs);
})();
</script>
}
