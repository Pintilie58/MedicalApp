@model MedicalApp.Areas.CAM.Models.CamPatientsListViewModel
@{
    ViewData["Title"] = Loc.T("CamPatientsTitle") + " — " + Model.ClinicName;
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
        <h2 class="text-primary fw-bold mb-0" data-testid="cam-patients-heading">
            &#128101; @Loc.T("CamPatientsHeading")
        </h2>
        <span class="badge bg-secondary align-self-center" data-testid="cam-patients-count">
            @Model.Items.Count
        </span>
        <div class="ms-auto">
            <a asp-controller="Dashboard" asp-action="Index" asp-area="CAM"
               class="btn btn-outline-secondary" data-testid="cam-back-dashboard">
                &larr; @Loc.T("CamBackDashboard")
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" data-testid="cam-patients-error">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" data-testid="cam-patients-success">@TempData["SuccessMessage"]</div>
    }

    <form method="get" class="mb-4" data-testid="cam-patients-search-form">
        <div class="input-group">
            <input name="q" value="@Model.Query" class="form-control"
                   placeholder="@Loc.T("CamPatientsSearchPlaceholder")"
                   data-testid="cam-patients-search-input" />
            <button class="btn btn-primary" type="submit" data-testid="cam-patients-search-submit">
                @Loc.T("CamPatientsSearchBtn")
            </button>
            @if (!string.IsNullOrWhiteSpace(Model.Query))
            {
                <a asp-action="Index" class="btn btn-outline-secondary" data-testid="cam-patients-clear">
                    @Loc.T("CamPatientsClearBtn")
                </a>
            }
        </div>
        <div class="form-text small">
            @Loc.T("CamPatientsSearchHint")
        </div>
    </form>

    @if (Model.Items.Count == 0)
    {
        <div class="alert alert-info" data-testid="cam-patients-empty">
            @if (string.IsNullOrWhiteSpace(Model.Query))
            {
                <span>@Loc.T("CamPatientsEmpty")</span>
            }
            else
            {
                <span>@Loc.T("CamPatientsNoMatch") „<strong>@Model.Query</strong>".</span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle" data-testid="cam-patients-table">
                <thead class="table-light">
                    <tr>
                        <th>@Loc.T("CamPatientsColName")</th>
                        <th>@Loc.T("CamPatientsColEmail")</th>
                        <th class="text-center">@Loc.T("CamPatientsColAnalyses")</th>
                        <th>@Loc.T("CamPatientsColAdded")</th>
                        <th class="text-end" style="width: 130px;">&nbsp;</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Items)
                    {
                        <tr data-testid="cam-patient-row-@p.Id">
                            <td class="fw-semibold">@p.Name</td>
                            <td><a href="mailto:@p.Email">@p.Email</a></td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@p.AnalysesCount</span>
                            </td>
                            <td class="small text-muted">@p.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="text-end">
                                <form asp-action="Delete" method="post" class="d-inline js-confirm-form"
                                      data-confirm-title="@Loc.T("CamPatientsDeleteTitle")"
                                      data-confirm-body="@string.Format(Loc.T("CamPatientsDeleteConfirmBody"), p.Name, p.AnalysesCount)"
                                      data-confirm-ok-label="@Loc.T("CamPatientsDeleteOk")"
                                      data-confirm-ok-class="btn-danger">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            title="@Loc.T("CamPatientsDeleteTooltip")"
                                            data-testid="cam-patient-delete-@p.Id">
                                        &#128465; @Loc.T("CamPatientsDeleteBtn")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<partial name="_ConfirmDialog" />
