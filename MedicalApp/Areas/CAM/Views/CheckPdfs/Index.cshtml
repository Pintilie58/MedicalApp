@model MedicalApp.Areas.CAM.Models.CamCheckPdfsViewModel
@{
    ViewData["Title"] = "Verificare PDF-uri — " + Model.ClinicName;
    int okCount = Model.Items.Count(r => r.IsValid);
    int notOkCount = Model.Items.Count - okCount;
    int goldCount = Model.Items.Count(r => r.MatchedExplicitBlock);
    int overrideCount = Model.Items.Count(r => r.IsManualOverride);
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
        <h2 class="text-primary fw-bold mb-0" data-testid="cam-checkpdfs-heading">
            &#128270; Verificare PDF-uri în folderul Original
        </h2>
        <div class="ms-auto">
            <a asp-controller="Dashboard" asp-action="Index" asp-area="CAM"
               class="btn btn-outline-secondary" data-testid="cam-back-dashboard">
                &larr; Înapoi la dashboard
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" data-testid="cam-checkpdfs-error">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" data-testid="cam-checkpdfs-success">@TempData["SuccessMessage"]</div>
    }

    <div class="alert alert-light border" data-testid="cam-checkpdfs-folder">
        <strong>Folder scanat:</strong>
        <code>@Model.OriginalFolder</code>
    </div>

    @* ===== Upload manual fișiere PDF (sugestia 1) ===== *@
    <div class="card mb-3 border-info">
        <div class="card-header bg-info-subtle fw-bold">
            &#128229; Selectare fișiere PDF (copiere din alt loc)
        </div>
        <div class="card-body">
            <p class="small text-muted mb-2">
                Selectează unul sau mai multe fișiere PDF de pe disc.
                Fișierele sunt <strong>copiate</strong> (nu mutate) în folderul <code>Original</code>
                al clinicii tale.
            </p>
            <form asp-action="UploadFiles" method="post" enctype="multipart/form-data"
                  class="d-flex flex-wrap gap-2" data-testid="cam-checkpdfs-upload-form">
                @Html.AntiForgeryToken()
                <input type="file" name="files" accept="application/pdf,.pdf" multiple required
                       class="form-control" style="max-width:520px;"
                       data-testid="cam-checkpdfs-upload-input" />
                <button type="submit" class="btn btn-info fw-bold"
                        data-testid="cam-checkpdfs-upload-submit">
                    &#9658; Copiază în Original
                </button>
            </form>
        </div>
    </div>

    @* ===== Help block [MedicalApp] ===== *@
    <div class="card mb-3 border-success">
        <div class="card-header bg-success-subtle fw-bold">
            &#11088; Convenție recomandată pentru identificare 100% sigură
        </div>
        <div class="card-body small">
            Adaugă pe ultima pagină a fiecărui PDF (sau în șablonul lab-ului) un bloc cu acest format <strong>exact</strong>:
            <pre class="bg-light p-2 mb-2 mt-2"
                 style="font-size:12px;border-radius:6px;">[MedicalApp]
Pacient: Ion Popescu
Email: ion.popescu@example.com</pre>
            Când blocul există, aplicația îl folosește direct (badge verde <strong>"[MedicalApp]"</strong>) și
            ignoră restul textului. Pentru PDF-urile fără bloc, aplicația apelează Gemini AI
            pentru a identifica numele pacientului automat din conținutul PDF-ului.
        </div>
    </div>

    @if (Model.FolderMissing)
    {
        <div class="alert alert-warning" data-testid="cam-checkpdfs-folder-missing">
            &#9888; Folderul nu există încă. Cumpără primul pachet de credite ca
            să fie creat automat.
        </div>
    }
    else
    {
        @* Rebucket rows: "ready" = override / explicit block / auto with name+email.
           Anything else where the PDF still looks medical is "AI-pending" (will be
           identified by Gemini at batch time). PDFs that aren't medical reports at
           all are the only truly-blocked rows. *@
        var aiPending = Model.Items.Count(r => !r.IsValid &&
            (r.Reason ?? "").Contains("Patient name not found", StringComparison.OrdinalIgnoreCase));
        var realErrors = notOkCount - aiPending;

        <div class="alert alert-info small mb-3" data-testid="cam-checkpdfs-help">
            &#128161; <strong>Cum decide aplicația cine e pacientul:</strong>
            (1) dacă există un override manual ✏ → folosește direct;
            (2) dacă PDF-ul conține blocul <code>[MedicalApp]</code> ⭐ → folosește direct;
            (3) altfel, la rularea lotului <strong>Gemini AI</strong> va citi PDF-ul și va
            identifica numele și emailul pacientului. Rândurile marcate „AI va identifica"
            sunt OK — vor fi procesate corect la lot.
        </div>

        <div class="d-flex gap-2 mb-3 flex-wrap" data-testid="cam-checkpdfs-summary">
            <span class="badge bg-success fs-6 px-3 py-2">&#10003; Gata: @okCount</span>
            <span class="badge bg-info fs-6 px-3 py-2 text-dark">&#129302; AI va identifica: @aiPending</span>
            @if (realErrors > 0)
            {
                <span class="badge bg-danger fs-6 px-3 py-2">&#10007; Blocate: @realErrors</span>
            }
            <span class="badge bg-success-subtle fs-6 px-3 py-2 text-success border border-success">&#11088; [MedicalApp]: @goldCount</span>
            <span class="badge bg-warning fs-6 px-3 py-2 text-dark">&#9999; Manual: @overrideCount</span>
            <span class="badge bg-secondary fs-6 px-3 py-2">Total: @Model.Items.Count</span>
            <div class="ms-auto">
                <form method="get" class="d-inline">
                    <button class="btn btn-outline-primary btn-sm" type="submit" data-testid="cam-checkpdfs-refresh">
                        &#10227; Re-scanează
                    </button>
                </form>
            </div>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="alert alert-info" data-testid="cam-checkpdfs-empty">
                Niciun PDF în folderul <code>Original</code>. Folosește butonul de mai sus pentru
                a copia fișiere, sau pune-le manual în folder și apasă „Re-scanează".
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle" data-testid="cam-checkpdfs-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width:36px;">&nbsp;</th>
                            <th>Fișier</th>
                            <th>Nume preview</th>
                            <th>Email preview</th>
                            <th>Sursă</th>
                            <th>Status</th>
                            <th style="width:160px;">&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Items)
                        {
                            // Decide the "real" status: ready / ai-pending / blocked.
                            var willBeAiResolved = !r.IsValid &&
                                (r.Reason ?? "").Contains("Patient name not found", StringComparison.OrdinalIgnoreCase);

                            string rowClass;
                            if (r.IsValid && r.MatchedExplicitBlock) rowClass = "table-success";
                            else if (r.IsValid && r.IsManualOverride) rowClass = "table-warning";
                            else if (r.IsValid) rowClass = "";
                            else if (willBeAiResolved) rowClass = "table-info";
                            else rowClass = "table-danger";

                            <tr class="@rowClass" data-testid="cam-checkpdfs-row">
                                <td class="text-center">
                                    @if (r.IsValid)
                                    {
                                        <span class="text-success fs-5">&#10003;</span>
                                    }
                                    else if (willBeAiResolved)
                                    {
                                        <span class="text-info fs-5">&#129302;</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fs-5">&#10007;</span>
                                    }
                                </td>
                                <td><code class="small">@r.FileName</code></td>
                                <td>@(r.PatientName ?? "—")</td>
                                <td>@(r.PatientEmail ?? "—")</td>
                                <td class="small">
                                    @if (r.MatchedExplicitBlock)
                                    {
                                        <span class="badge bg-success">&#11088; [MedicalApp]</span>
                                    }
                                    else if (r.IsManualOverride)
                                    {
                                        <span class="badge bg-warning text-dark">&#9999; Manual</span>
                                    }
                                    else if (r.IsValid)
                                    {
                                        <span class="badge bg-secondary">Auto</span>
                                    }
                                    else if (willBeAiResolved)
                                    {
                                        <span class="badge bg-info text-dark">AI la lot</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Blocat</span>
                                    }
                                </td>
                                <td class="small">
                                    @if (r.IsValid)
                                    {
                                        <span class="text-success">Gata pentru lot.</span>
                                    }
                                    else if (willBeAiResolved)
                                    {
                                        <span class="text-info">
                                            Gemini va identifica pacientul la lot.
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">@r.Reason</span>
                                    }
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal"
                                            data-filename="@r.FileName"
                                            data-name="@(r.PatientName ?? "")"
                                            data-email="@(r.PatientEmail ?? "")"
                                            data-testid="cam-checkpdfs-edit-btn">
                                        &#9999; Editează
                                    </button>
                                    @if (r.IsManualOverride)
                                    {
                                        <form asp-action="ClearOverride" method="post" class="d-inline ms-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="fileName" value="@r.FileName" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-secondary"
                                                    title="Șterge override-ul manual și revine la auto-extracție"
                                                    data-testid="cam-checkpdfs-clear-btn">
                                                &#10005;
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@* ===== Modal Edit Override (un singur modal reutilizat pentru toate rândurile) ===== *@
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="SaveOverride" method="post" class="modal-content"
              data-testid="cam-checkpdfs-edit-form">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title">&#9999; Editează metadata pacient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="small text-muted">
                    Datele introduse aici sunt folosite la lansarea lotului în locul auto-extracției.
                </p>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Fișier</label>
                    <input type="text" id="editFileName" name="fileName"
                           class="form-control bg-light" readonly
                           data-testid="cam-checkpdfs-edit-filename" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Nume complet pacient</label>
                    <input type="text" id="editName" name="overrideName" required
                           class="form-control"
                           placeholder="ex: Ion Popescu"
                           data-testid="cam-checkpdfs-edit-name" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Email pacient</label>
                    <input type="email" id="editEmail" name="overrideEmail" required
                           class="form-control"
                           placeholder="ex: ion.popescu@example.com"
                           data-testid="cam-checkpdfs-edit-email" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Renunță</button>
                <button type="submit" class="btn btn-primary fw-bold"
                        data-testid="cam-checkpdfs-edit-save">Salvează</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var editModal = document.getElementById('editModal');
        if (!editModal) return;
        editModal.addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('editFileName').value = btn.getAttribute('data-filename') || '';
            document.getElementById('editName').value     = btn.getAttribute('data-name')     || '';
            document.getElementById('editEmail').value    = btn.getAttribute('data-email')    || '';
        });
    });
</script>
}
