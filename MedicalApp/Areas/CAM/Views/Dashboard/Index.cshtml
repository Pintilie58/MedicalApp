@model MedicalApp.Areas.CAM.Models.CamDashboardViewModel
@using MedicalApp.Services
@{
    ViewData["Title"] = Loc.T("CamDashTitle");
    Layout = "~/Views/Shared/_Layout.cshtml";

    string StatusBadge(string status) => status?.ToLowerInvariant() switch
    {
        "completed" => "bg-success",
        "running"   => "bg-primary",
        "cancelled" => "bg-warning text-dark",
        "failed"    => "bg-danger",
        _ => "bg-secondary"
    };

    // Display-only translation of the English DB status values. The underlying
    // string in ClinicBatchRun.Status stays English ("Completed", "Failed",
    // "Cancelled", "Running") so all backend logic and the StatusBadge() switch
    // above keep working unchanged.
    string StatusLocalized(string status) => status?.ToLowerInvariant() switch
    {
        "completed" => Loc.T("CamDashStatusCompleted"),
        "running"   => Loc.T("CamDashStatusRunning"),
        "cancelled" => Loc.T("CamDashStatusCancelled"),
        "failed"    => Loc.T("CamDashStatusFailed"),
        _ => status ?? "—"
    };
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col-auto" style="margin-top: -4rem;" data-testid="cam-mascot-col">
            @{
                var camDashMascotVd = new ViewDataDictionary(ViewData)
                {
                    ["Mode"] = "greeting",
                    ["Size"] = "small",
                    ["StageId"] = "camDashGreeting",
                    ["TestId"] = "cam-dashboard-mascot",
                    ["BubbleText"] = string.Format(Loc.T("CamDashGreeting"), Model.ClinicName)
                };
            }
            <partial name="_DoctorMascot" view-data="camDashMascotVd" />
        </div>
        <div class="col">
            <h1 class="h2 fw-bold text-primary mb-1" data-testid="cam-dashboard-heading">
                @Model.ClinicName
            </h1>
            <div class="text-muted small">
                @Model.ClinicCity &middot; @Model.ClinicAddress
            </div>
        </div>
        <div class="col-auto align-self-center text-end">
            <span class="badge bg-success fs-6 px-3 py-2 d-block mb-2" data-testid="cam-credits-badge">
                @string.Format(Loc.T("CamDashCreditsAvailableBadge"), Model.CreditsAvailable)
            </span>
            <a asp-controller="Credits" asp-action="Buy" asp-area=""
               class="btn btn-sm btn-outline-success fw-semibold"
               data-testid="cam-header-buy-credits"
               title="@Loc.T("CamDashBuyCreditsTooltip")">
                <i class="bi bi-cart-plus"></i> @Loc.T("CamDashBuyCredits")
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" data-testid="cam-error">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" data-testid="cam-success">@TempData["SuccessMessage"]</div>
    }

    @* ============================================================
       A5 — Banner: last batch failed to send some emails.
       Shown ONLY while the most recently finished batch has NotSends > 0.
       As soon as the operator runs a clean batch, the banner disappears
       automatically (controller recomputes on every GET).
       ============================================================ *@
    @if (Model.RecentEmailIssues != null)
    {
        <div class="alert alert-warning d-flex align-items-start gap-3"
             data-testid="cam-recent-email-issues">
            <div style="font-size: 1.8rem; line-height: 1;">&#9888;</div>
            <div class="flex-grow-1">
                <h5 class="fw-bold mb-1">
                    @string.Format(Loc.T("CamDashEmailIssuesHeader"),
                        Model.RecentEmailIssues.NotSends,
                        Model.RecentEmailIssues.TotalFiles)
                </h5>
                <p class="mb-2 small">
                    @{
                        var finishedAtStr = Model.RecentEmailIssues.FinishedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm");
                    }
                    @Html.Raw(string.Format(Loc.T("CamDashEmailIssuesBody"),
                        Model.RecentEmailIssues.BatchRunId,
                        "<strong>" + System.Net.WebUtility.HtmlEncode(finishedAtStr) + "</strong>"))
                </p>
                @if (Model.RecentEmailIssues.SampleReasons.Count > 0)
                {
                    <ul class="small mb-2" data-testid="cam-recent-email-issues-list">
                        @foreach (var reason in Model.RecentEmailIssues.SampleReasons)
                        {
                            <li>@reason</li>
                        }
                    </ul>
                }
                <a asp-controller="CheckPdfs" asp-action="Index" asp-area="CAM"
                   class="btn btn-warning btn-sm fw-bold"
                   data-testid="cam-recent-email-issues-fix">
                    &#9999; @Html.Raw(Loc.T("CamDashEmailIssuesFix"))
                </a>
                <a asp-controller="Dashboard" asp-action="SumarPdf" asp-area="CAM"
                   asp-route-id="@Model.RecentEmailIssues.BatchRunId"
                   target="_blank"
                   class="btn btn-outline-secondary btn-sm ms-1"
                   data-testid="cam-recent-email-issues-details">
                    &#128196; @Loc.T("CamDashDownloadSumar")
                </a>
            </div>
        </div>
    }

    @if (!Model.FoldersCreated)
    {
        <div class="alert alert-warning d-flex align-items-start" data-testid="cam-folders-pending">
            <div class="me-3" style="font-size: 1.6rem;">&#9888;</div>
            <div>
                <h5 class="fw-bold mb-1">@Loc.T("CamDashFoldersPending")</h5>
                <p class="mb-2">
                    @Html.Raw(Loc.T("CamDashFoldersPendingBody"))
                </p>
                <a asp-controller="Credits" asp-action="Buy" asp-area=""
                   class="btn btn-warning fw-bold" data-testid="cam-go-buy-credits">
                    @Html.Raw(Loc.T("CamDashBuyFirstCredits"))
                </a>
            </div>
        </div>
    }
    else
    {
        @* ============================================================
           KPI CARDS — Phase 4
           ============================================================ *@
        <div class="row g-3 mb-4" data-testid="cam-kpi-row">
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm h-100" style="background:#E7F1FF;">
                    <div class="card-body py-3">
                        <div class="display-6 fw-bold text-primary" data-testid="cam-kpi-interpreted">
                            @Model.LifetimeFilesInterpreted
                        </div>
                        <div class="small text-muted">@Loc.T("CamDashKpiInterpreted")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm h-100" style="background:#D1E7DD;">
                    <div class="card-body py-3">
                        <div class="display-6 fw-bold text-success" data-testid="cam-kpi-sent">
                            @Model.LifetimeFilesSent
                        </div>
                        <div class="small text-muted">@Loc.T("CamDashKpiSent")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm h-100" style="background:#CFF4FC;">
                    <div class="card-body py-3">
                        <div class="display-6 fw-bold text-info" data-testid="cam-kpi-compared">
                            @Model.LifetimeFilesCompared
                        </div>
                        <div class="small text-muted">@Loc.T("CamDashKpiCompared")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card border-0 shadow-sm h-100" style="background:#FFF3CD;">
                    <div class="card-body py-3">
                        <div class="display-6 fw-bold text-warning" data-testid="cam-kpi-notsends">
                            @Model.LifetimeNotSends
                        </div>
                        <div class="small text-muted">@Loc.T("CamDashKpiNotSends")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4" data-testid="cam-batchstats-row">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-muted small mb-0">@Loc.T("CamDashBatchesHeader")</h6>
                        </div>

                        @* Row 1 — selected year (top-left dropdown) *@
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="small text-muted" data-testid="cam-batches-year-label">
                                @string.Format(Loc.T("CamDashBatchesYearLabel"), Model.CurrentYear)
                            </div>
                            @{
                                var localUrl = Url.Action("Index", new { area = "CAM" }) ?? "/CAM/Dashboard";
                            }
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle py-0 px-2"
                                        type="button"
                                        id="yearDropdownBtn"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false"
                                        data-testid="cam-year-dropdown-btn">
                                    @Model.SelectedYear
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    aria-labelledby="yearDropdownBtn"
                                    data-testid="cam-year-dropdown-menu">
                                    @foreach (var y in Model.AvailableYears)
                                    {
                                        var url = $"{localUrl}?year={y}&month={Model.SelectedMonth}";
                                        var active = y == Model.SelectedYear ? "active" : "";
                                        <li>
                                            <a class="dropdown-item @active" href="@url"
                                               data-testid="cam-year-option-@y">
                                                @y
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3 mb-3" data-testid="cam-batches-year-row">
                            <div>
                                <div class="fs-3 fw-bold" data-testid="cam-year-total">@Model.YearStats.Total</div>
                                <div class="small text-muted">@Loc.T("CamDashTotal")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-success" data-testid="cam-year-completed">@Model.YearStats.Completed</div>
                                <div class="small text-muted">@Loc.T("CamDashCompleted")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-danger" data-testid="cam-year-failed">@Model.YearStats.Failed</div>
                                <div class="small text-muted">@Loc.T("CamDashFailed")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-warning" data-testid="cam-year-cancelled">@Model.YearStats.Cancelled</div>
                                <div class="small text-muted">@Loc.T("CamDashCancelled")</div>
                            </div>
                            <div class="ms-auto">
                                <div class="fs-3 fw-bold text-info" data-testid="cam-year-patients">@Model.YearStats.Patients</div>
                                <div class="small text-muted">@Loc.T("CamDashPatients")</div>
                            </div>
                        </div>

                        <hr class="my-2" />

                        @* Row 2 — selected month of the selected year *@
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="small text-muted" data-testid="cam-batches-month-label">
                                @string.Format(Loc.T("CamDashBatchesMonthLabel"), Model.CurrentMonthLabel)
                            </div>
                            @{
                                // Use the current UI culture so month names follow the selected language.
                                var monthCulture = System.Globalization.CultureInfo.CurrentUICulture;
                                string MonthLabel(int m)
                                {
                                    var n = monthCulture.DateTimeFormat.GetMonthName(m);
                                    if (n.Length == 0) return m.ToString();
                                    return char.ToUpper(n[0], monthCulture) + n.Substring(1);
                                }
                            }
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle py-0 px-2"
                                        type="button"
                                        id="monthDropdownBtn"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false"
                                        data-testid="cam-month-dropdown-btn">
                                    @MonthLabel(Model.SelectedMonth)
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    aria-labelledby="monthDropdownBtn"
                                    style="max-height: 320px; overflow-y: auto;"
                                    data-testid="cam-month-dropdown-menu">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        var url = $"{localUrl}?year={Model.SelectedYear}&month={m}";
                                        var active = m == Model.SelectedMonth ? "active" : "";
                                        <li>
                                            <a class="dropdown-item @active" href="@url"
                                               data-testid="cam-month-option-@m">
                                                @MonthLabel(m)
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3" data-testid="cam-batches-month-row">
                            <div>
                                <div class="fs-3 fw-bold" data-testid="cam-month-total">@Model.MonthStats.Total</div>
                                <div class="small text-muted">@Loc.T("CamDashTotal")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-success" data-testid="cam-month-completed">@Model.MonthStats.Completed</div>
                                <div class="small text-muted">@Loc.T("CamDashCompleted")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-danger" data-testid="cam-month-failed">@Model.MonthStats.Failed</div>
                                <div class="small text-muted">@Loc.T("CamDashFailed")</div>
                            </div>
                            <div>
                                <div class="fs-3 fw-bold text-warning" data-testid="cam-month-cancelled">@Model.MonthStats.Cancelled</div>
                                <div class="small text-muted">@Loc.T("CamDashCancelled")</div>
                            </div>
                            <div class="ms-auto">
                                <div class="fs-3 fw-bold text-info" data-testid="cam-month-patients">@Model.MonthStats.Patients</div>
                                <div class="small text-muted">@Loc.T("CamDashPatients")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="fw-bold text-muted small mb-2">@Loc.T("CamDashQuickActions")</h6>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <a asp-controller="Batch" asp-action="Start" asp-area="CAM"
                               class="btn btn-primary fw-bold" data-testid="cam-go-batch">
                                @Loc.T("CamDashLaunchBatch")
                            </a>
                            <a asp-controller="Patients" asp-action="Index" asp-area="CAM"
                               class="btn btn-outline-primary" data-testid="cam-go-patients">
                                @Loc.T("CamDashGotoPatients")
                            </a>
                            <a asp-controller="CheckPdfs" asp-action="Index" asp-area="CAM"
                               class="btn btn-outline-secondary" data-testid="cam-go-checkpdfs">
                                @Loc.T("CamDashGotoCheckPdfs")
                            </a>
                        </div>

                        <hr class="my-2" />

                        @* ----------- Disk usage + Cleanup ----------- *@
                        @{
                            var warn = Model.DiskWarnLevel;
                            var warnClass = warn == 2 ? "text-danger"
                                          : warn == 1 ? "text-warning"
                                          : "text-muted";
                        }
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <h6 class="fw-bold text-muted small mb-0">@Loc.T("CamDashDiskUsage")</h6>
                            <span class="small @warnClass fw-bold" data-testid="cam-disk-summary">
                                @Model.DiskHumanTotal · @Model.DiskFilesTotal @Loc.T("CamDashFiles")
                            </span>
                        </div>
                        @{
                            string FormatBytes(long b)
                            {
                                double s = b;
                                string[] units = { "B", "KB", "MB", "GB" };
                                int i = 0;
                                while (s >= 1024 && i < units.Length - 1) { s /= 1024; i++; }
                                return $"{s:0.##} {units[i]}";
                            }
                        }
                        <div class="small text-muted mb-2" data-testid="cam-disk-breakdown">
                            <span title="@Loc.T("CamDashOriginalNotAffected")">
                                Original: <strong>@FormatBytes(Model.DiskBytesOriginal)</strong>
                            </span>
                            <span class="ms-2">·</span>
                            <span class="ms-2">Sends: <strong>@FormatBytes(Model.DiskBytesSends)</strong></span>
                            <span class="ms-2">·</span>
                            <span class="ms-2">Sumar: <strong>@FormatBytes(Model.DiskBytesSumar)</strong></span>
                            <span class="ms-2">·</span>
                            <span class="ms-2">Errors: <strong>@FormatBytes(Model.DiskBytesErrors)</strong></span>
                        </div>
                        @if (warn > 0)
                        {
                            <div class="alert @(warn == 2 ? "alert-danger" : "alert-warning") py-1 px-2 small mb-2"
                                 data-testid="cam-disk-warning">
                                @if (warn == 2)
                                {
                                    <span>@Loc.T("CamDashDiskWarnRed")</span>
                                }
                                else
                                {
                                    <span>@Loc.T("CamDashDiskWarnYellow")</span>
                                }
                            </div>
                        }
                        <form asp-action="Cleanup" method="post" class="d-flex gap-2 align-items-center js-confirm-form"
                              data-confirm-title="@Loc.T("CamDashCleanupConfirmTitle")"
                              data-confirm-body="@Loc.T("CamDashCleanupConfirmBody")"
                              data-confirm-ok-label="@Loc.T("CamDashCleanupConfirmOk")"
                              data-confirm-ok-class="btn-danger">
                            @Html.AntiForgeryToken()
                            <label for="cleanupDays" class="small text-muted mb-0">@Loc.T("CamDashOlderThan")</label>
                            <input type="number" class="form-control form-control-sm" id="cleanupDays"
                                   name="days" value="@Model.RetentionDaysDefault" min="1" max="365"
                                   style="width: 80px;" data-testid="cam-cleanup-days" />
                            <span class="small text-muted">@Loc.T("CamDashDays")</span>
                            <button type="submit" class="btn btn-sm btn-outline-danger ms-auto"
                                    data-testid="cam-cleanup-btn">
                                &#129529; @Loc.T("CamDashCleanupNow")
                            </button>
                        </form>
                        <div class="small text-muted mt-2">
                            @Loc.T("CamDashCleanupHint")
                            <span class="text-secondary">@Loc.T("CamDashOriginalNeverTouched")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ============================================================
           RECENT BATCHES HISTORY
           ============================================================ *@
        <div class="card mb-4">
            <div class="card-header bg-white d-flex align-items-center">
                <span class="fw-bold">@Loc.T("CamDashHistoryTitle")</span>
                <span class="badge bg-secondary ms-2">@Model.RecentBatches.Count</span>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentBatches.Count == 0)
                {
                    <div class="text-muted small p-3" data-testid="cam-batches-empty">
                        @Html.Raw(Loc.T("CamDashHistoryEmpty"))
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle" data-testid="cam-batches-table">
                            <thead class="table-light">
                                <tr>
                                    <th>@Loc.T("CamDashColIndex")</th>
                                    <th>@Loc.T("CamDashColStarted")</th>
                                    <th>@Loc.T("CamDashColDuration")</th>
                                    <th class="text-center">@Loc.T("CamDashColStatus")</th>
                                    <th class="text-end">@Loc.T("CamDashColTotal")</th>
                                    <th class="text-end">@Loc.T("CamDashColSent")</th>
                                    <th class="text-end">@Loc.T("CamDashColCompared")</th>
                                    <th class="text-end">@Loc.T("CamDashColNotSends")</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.RecentBatches)
                                {
                                    <tr data-testid="cam-batch-row-@b.BatchRunId">
                                        <td class="text-muted small">#@b.BatchRunId</td>
                                        <td>@b.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-muted small">@b.DurationDisplay</td>
                                        <td class="text-center">
                                            <span class="badge @StatusBadge(b.Status)" data-testid="cam-batch-status-@b.BatchRunId">
                                                @StatusLocalized(b.Status)
                                            </span>
                                        </td>
                                        <td class="text-end">@b.TotalFiles</td>
                                        <td class="text-end text-success fw-semibold">@b.FilesSent</td>
                                        <td class="text-end text-info fw-semibold">@b.FilesCompared</td>
                                        <td class="text-end text-warning fw-semibold">@b.NotSends</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-controller="Batch" asp-action="Progress" asp-area="CAM"
                                                   asp-route-id="@b.BatchRunId"
                                                   class="btn btn-outline-secondary"
                                                   data-testid="cam-batch-progress-link-@b.BatchRunId"
                                                   title="@Loc.T("CamDashProgressTooltip")">
                                                    @Loc.T("CamDashProgress")
                                                </a>
                                                <a asp-action="SumarPdf" asp-route-id="@b.BatchRunId"
                                                   class="btn btn-outline-primary"
                                                   data-testid="cam-batch-sumarpdf-link-@b.BatchRunId"
                                                   title="@Loc.T("CamDashSumarPdfTooltip")">
                                                    @Loc.T("CamDashSumarPdf")
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ============================================================
           FOLDERS PANEL (collapsible)
           ============================================================ *@
        <div class="card mb-4">
            <div class="card-header bg-white">
                <button class="btn btn-link p-0 text-decoration-none fw-bold"
                        type="button" data-bs-toggle="collapse"
                        data-bs-target="#foldersPanel" aria-expanded="false"
                        data-testid="cam-folders-toggle">
                    @Loc.T("CamDashFoldersPanel")
                    <span class="text-muted small fw-normal">
                        @string.Format(Loc.T("CamDashFoldersCreatedAt"),
                            Model.FoldersCreatedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm"))
                    </span>
                </button>
            </div>
            <div id="foldersPanel" class="collapse">
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr><td style="width: 120px;"><strong>Original</strong></td><td><code>@Model.OriginalFolder</code></td></tr>
                            <tr><td><strong>Sends</strong></td><td><code>@Model.SendsFolder</code></td></tr>
                            <tr><td><strong>Sumar</strong></td><td><code>@Model.SumarFolder</code></td></tr>
                            <tr><td><strong>Errors</strong></td><td><code>@Model.ErrorsFolder</code></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="text-center mt-5">
        <p class="small text-muted">
            Powered by <a href="https://medicalapp.ro" target="_blank" class="text-decoration-none fw-bold">MedicalApp+</a>
            &middot; <a asp-controller="Account" asp-action="Dashboard" asp-area="" class="text-decoration-none">@Loc.T("CamDashSwitchPersonal")</a>
        </p>
    </div>
</div>

<partial name="_ConfirmDialog" />

@section Scripts {
@* Dashboard no longer uses Chart.js — yearly/monthly aggregates are displayed directly as numbers. *@
}
