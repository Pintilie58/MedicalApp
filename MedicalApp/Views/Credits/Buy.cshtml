@model IReadOnlyList<MedicalApp.Services.CreditPackage>
@{
    ViewData["Title"] = Loc.T("BuyCreditsTitle");
    var lowCreditsWarning = TempData["LowCreditsWarning"] as string;
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="text-primary fw-bold">@Loc.T("BuyCreditsTitle")</h2>
        <p class="text-muted">@Loc.T("BuyCreditsIntro")</p>
    </div>

    @if (!string.IsNullOrEmpty(lowCreditsWarning))
    {
        <div class="alert alert-warning text-center">@lowCreditsWarning</div>
    }

    <div class="alert alert-info d-flex justify-content-center align-items-center gap-3 flex-wrap">
        <span><strong>@Loc.T("PaidCreditsLabel"):</strong> @ViewBag.PaidRemaining</span>
        <span class="text-muted">|</span>
        <span><strong>@Loc.T("BonusCreditsLabel"):</strong> @ViewBag.BonusRemaining</span>
        <span class="text-muted">|</span>
        <span>
            <strong>@Loc.T("TotalAvailableLabel"):</strong>
            <span class="fw-bold text-success">@ViewBag.TotalAvailable</span>
        </span>
    </div>

    <div class="row g-4 justify-content-center mt-2">
        @{
            // 3 boxes for CAM (Clinic audience) → col-lg-4 fills the row.
            // 4 boxes for B2C (Individual)     → col-lg-3 fills the row.
            // 1-2 boxes fall back to a tighter layout, still centered.
            var colCls = Model.Count switch
            {
                <= 2 => "col-md-6 col-lg-5",
                3    => "col-md-6 col-lg-4",
                _    => "col-md-6 col-lg-3"
            };
        }
        @foreach (var pkg in Model)
        {
            var isPopular = pkg.Key == "super" || pkg.Key == "cam_business";
            var cardClass = isPopular ? "border-primary shadow-lg pkg-popular" : "shadow-sm";
            <div class="@colCls">
                <div class="card h-100 border-0 @cardClass position-relative">
                    @if (isPopular)
                    {
                        <span class="badge bg-primary position-absolute start-50 px-3 py-2 pkg-popular-badge">
                            @Loc.T("MostPopular")
                        </span>
                    }
                    <div class="card-body text-center d-flex flex-column">
                        <h4 class="card-title mt-2">@Loc.T(pkg.NameKey)</h4>
                        <div class="my-3">
                            <span class="display-4 fw-bold text-primary">@pkg.PriceEur.ToString("0")€</span>
                        </div>
                        <div class="mb-3">
                            <span class="fs-3 fw-semibold">@pkg.Credits</span>
                            <div class="text-muted small">@Loc.T("CreditsLabel")</div>
                        </div>
                        <div class="text-muted small mb-3">
                            @((pkg.PriceEur / pkg.Credits).ToString("0.00"))€ / @Loc.T("CreditUnit")
                        </div>
                        <a asp-action="Checkout" asp-route-package="@pkg.Key"
                           class="btn btn-primary mt-auto">
                            @Loc.T("ChoosePackage")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        @{
            // Clinic users go back to the CAM dashboard so the navbar mode
            // stays B2B; Individual users keep the B2C destination.
            var _audienceForBack = ViewBag.Audience as string;
        }
        @if (string.Equals(_audienceForBack, "Clinic", StringComparison.OrdinalIgnoreCase))
        {
            <a asp-controller="Dashboard" asp-action="Index" asp-area="CAM"
               class="text-decoration-none small text-muted"
               data-testid="credits-back-to-cam">
                &larr; @Loc.T("BackToDashboard")
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Dashboard" asp-area=""
               class="text-decoration-none small text-muted"
               data-testid="credits-back-to-b2c">
                &larr; @Loc.T("BackToDashboard")
            </a>
        }
    </div>
</div>

<style>
    /* Make the "Most popular" ribbon sit fully inside the card, anchored
       at the top edge, so it isn't half-clipped above the card body. */
    .pkg-popular { padding-top: 18px; }
    .pkg-popular-badge {
        top: 12px;
        transform: translateX(-50%);
        z-index: 5;
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.30);
        letter-spacing: 0.02em;
    }
</style>
