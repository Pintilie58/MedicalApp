@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Loc.T("AppTitle")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/doctor-mascot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/password-toggle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile-tooltip.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">@Loc.T("AppTitle")</a>
                <div class="ms-auto d-flex align-items-center gap-2">
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UserEmail")))
                    {
                        var _layoutEmail = Context.Session.GetString("UserEmail")!;
                        var _layoutDb = Context.RequestServices.GetService(typeof(AppDbContext)) as AppDbContext;
                        var _layoutUser = _layoutDb?.Users.AsNoTracking().FirstOrDefault(u => u.Email == _layoutEmail);

                        if (_layoutUser != null)
                        {
                            // Credits widget: shows paid + bonus, color-coded by total available
                            var _navPaid = _layoutUser.CreditRest;
                            var _navBonus = _layoutUser.BonusCreditsRemaining;
                            var _navTotal = _navPaid + _navBonus;
                            var _navBadgeClass = _navTotal <= 0 ? "bg-danger"
                            : _navTotal <= 5 ? "bg-warning text-dark"
                            : "bg-success";
                            var _navTooltip = string.Format(Loc.T("NavCreditsTooltip"), _navPaid, _navBonus);

                            <a asp-area="" asp-controller="Account" asp-action="Dashboard"
                               class="d-inline-flex align-items-center text-decoration-none me-2"
                               title="@_navTooltip" data-testid="navbar-credits-widget">
                                <span class="badge @_navBadgeClass fw-bold py-2 px-3"
                                      style="font-size: 0.85rem; border-radius: 20px;">
                                    &#128176; @_navTotal
                                    @if (_navBonus > 0)
                                    {
                                        <span class="ms-1 small fw-normal">(+@_navBonus @Loc.T("BonusShort"))</span>
                                    }
                                </span>
                            </a>
                        }

                        if (_layoutUser != null && _layoutUser.IsAdmin)
                        {
                            <a asp-area="" asp-controller="Admin" asp-action="Index"
                               class="btn btn-sm btn-warning fw-bold" data-testid="admin-nav-link">
                                &#9881; Admin
                            </a>
                        }

                        @* CAM toggle: only for Clinic users — lets them jump between
                           personal (B2C) and clinic (CAM) modes from one place.
                           NOTE: /Credits/... is also treated as "still in B2B mode"
                           for Clinic users so a top-up purchase doesn't make the
                           navbar look like it switched to personal mode. *@
                        if (_layoutUser != null &&
                            string.Equals(_layoutUser.UserType, "Clinic", StringComparison.OrdinalIgnoreCase))
                        {
                            var _path = Context.Request.Path.Value ?? "";
                            var _isOnCamArea =
                                _path.StartsWith("/CAM", StringComparison.OrdinalIgnoreCase) ||
                                _path.StartsWith("/Credits", StringComparison.OrdinalIgnoreCase);
                            if (_isOnCamArea)
                            {
                                <a asp-controller="Account" asp-action="Dashboard" asp-area=""
                                   class="btn btn-sm btn-outline-light fw-bold" data-testid="nav-mode-personal"
                                   title="@Loc.T("NavModePersonalTooltip")">
                                    &#128106; @Loc.T("NavModePersonal")
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Dashboard" asp-action="Index" asp-area="CAM"
                                   class="btn btn-sm btn-info fw-bold text-dark" data-testid="nav-mode-cam"
                                   title="@Loc.T("NavModeClinicTooltip")">
                                    &#127973; @Loc.T("NavModeClinic")
                                </a>
                            }
                        }

                        @* Profiles quick link - only for logged-in users *@
                        if (_layoutUser != null)
                        {
                            <a asp-area="" asp-controller="Profiles" asp-action="Index"
                               class="btn btn-sm btn-outline-light" data-testid="nav-profiles-link"
                               title="@Loc.T("NavProfilesTooltip")">
                                &#128106; @Loc.T("NavProfiles")
                            </a>
                        }

                        <span class="text-white small me-2">@_layoutEmail</span>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-light">@Loc.T("Logout")</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - @Loc.T("AppTitle")
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>
    <script src="~/js/doctor-mascot.js" asp-append-version="true"></script>

    @* ============================================================
       Smart language auto-detect (runs once per browser).
       ASP.NET Core's RequestLocalization already honors the
       Accept-Language HTTP header on the FIRST request, so most
       visitors land in their browser language out of the box. This
       small helper makes that decision PERMANENT by writing the
       .AspNetCore.Culture cookie on the first render — and provides
       a JS fallback (navigator.language) for the edge case where the
       Accept-Language header is suppressed (privacy extensions,
       certain mobile browsers). One-shot: a sessionStorage flag
       prevents reload loops.
       ============================================================ *@
    <script>
    (function () {
        try {
            if (sessionStorage.getItem('langAutoChecked') === '1') return;
            sessionStorage.setItem('langAutoChecked', '1');

            // Single source of truth: SupportedLanguagesConfig.Codes. Rendered
            // server-side so the array stays in sync with the C# config.
            var supported = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                MedicalApp.Services.SupportedLanguagesConfig.Codes));
            var currentLang = (document.documentElement.lang || 'en').toLowerCase().substring(0,2);

            // Cookie lookup — same name ASP.NET Core uses by default.
            function readCookie(name) {
                var m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
                return m ? decodeURIComponent(m[1]) : null;
            }
            var cookieRaw = readCookie('.AspNetCore.Culture');
            var hasCookie = cookieRaw && cookieRaw.indexOf('uic=') !== -1;

            // Pick best browser language from navigator.languages, then navigator.language.
            var navLangs = (navigator.languages && navigator.languages.length)
                ? navigator.languages
                : [navigator.language || 'en'];
            var pick = null;
            for (var i = 0; i < navLangs.length; i++) {
                var two = (navLangs[i] || '').toLowerCase().substring(0,2);
                if (supported.indexOf(two) !== -1) { pick = two; break; }
            }
            if (!pick) pick = 'en';

            // Helper: write the cookie in the exact format
            // CookieRequestCultureProvider expects: "c=xx|uic=xx".
            function writeCultureCookie(lang) {
                var val = 'c=' + lang + '|uic=' + lang;
                // 1 year, root path, SameSite=Lax — matches ASP.NET Core defaults.
                document.cookie = '.AspNetCore.Culture=' + encodeURIComponent(val)
                    + '; Max-Age=31536000; Path=/; SameSite=Lax';
            }

            if (!hasCookie) {
                if (pick !== currentLang) {
                    // Browser prefers a different supported language than the one
                    // the server rendered (likely because Accept-Language was
                    // suppressed and the default "en" was used). Persist the
                    // user's real choice and reload so the new strings appear.
                    writeCultureCookie(pick);
                    window.location.reload();
                } else {
                    // Already correct — just make it sticky for future visits
                    // and so the language dropdown reflects the active choice.
                    writeCultureCookie(currentLang);
                }
            }
        } catch (e) { /* never break the page on a localization helper */ }
    })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @* ---- Universal helpers loaded on every page ----
       password-toggle: adds an eye 👁 button to every <input type="password">.
       mobile-tooltip:  turns native `title="..."` into tap-friendly tooltips
                        on touch-only devices (@@media hover: none).
       Both are self-contained, auto-init, and share `window.MedicalApp.i18n`
       for localised aria/title strings. *@
    <script>
        window.MedicalApp = window.MedicalApp || {};
        window.MedicalApp.i18n = Object.assign(window.MedicalApp.i18n || {}, {
            passwordShow: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Loc.T("PasswordToggleShow"))),
            passwordHide: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Loc.T("PasswordToggleHide")))
        });
    </script>
    <script src="~/js/password-toggle.js" asp-append-version="true"></script>
    <script src="~/js/mobile-tooltip.js" asp-append-version="true"></script>
</body>
</html>
