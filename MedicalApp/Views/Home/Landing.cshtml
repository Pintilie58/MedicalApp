@{
    Layout = null;
    ViewData["Title"] = "MedicalApp — AI Medical Analysis Interpretation";
    var current = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var langs = new (string code, string label)[]
    {
        ("en", "English"),
        ("ro", "Română"),
        ("fr", "Français"),
        ("es", "Español"),
        ("de", "Deutsch")
    };
    string AuthUrl(string tab) => Url.Action("Auth", "Home", new { tab = tab }) ?? "/Home/Auth";
}
<!DOCTYPE html>
<html lang="@current">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="@Loc.T("LandingMetaDesc")" />
    <link rel="icon" href="~/favicon.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
          crossorigin="anonymous" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body class="landing-body">

@* =========================== NAVBAR =========================== *@
<nav class="land-nav" data-testid="land-nav">
    <div class="land-nav-inner">
        <a class="land-brand" href="/" data-testid="land-brand">
            <span class="land-brand-mark">M+</span> MedicalApp+
        </a>
        <ul class="land-nav-links">
            <li><a href="#how" data-testid="nav-how">@Loc.T("NavHow")</a></li>
            <li><a href="#compare" data-testid="nav-compare">@Loc.T("CompareEyebrow")</a></li>
            <li><a href="#features" data-testid="nav-features">@Loc.T("NavFeatures")</a></li>
            <li><a href="#clinics" data-testid="nav-clinics">@Loc.T("NavClinics")</a></li>
            <li><a href="#pricing" data-testid="nav-pricing">@Loc.T("NavPricing")</a></li>
        </ul>
        <div class="d-flex align-items-center gap-2">
            <div class="land-lang">
                <button class="land-lang-btn" id="landLangBtn" aria-haspopup="true" aria-expanded="false"
                        data-testid="land-lang-btn">
                    @current.ToUpper()
                    <span aria-hidden="true">▾</span>
                </button>
                <div class="land-lang-menu d-none" id="landLangMenu" data-testid="land-lang-menu">
                    @foreach (var l in langs)
                    {
                        <form asp-controller="Home" asp-action="SetLanguage" method="post">
                            <input type="hidden" name="culture" value="@l.code" />
                            <input type="hidden" name="returnUrl" value="/" />
                            <button type="submit" data-testid="land-lang-@l.code">@l.label</button>
                        </form>
                    }
                </div>
            </div>
            <a href="@AuthUrl("login")" class="land-btn land-btn-ghost" data-testid="land-signin">
                @Loc.T("NavSignIn")
            </a>
            <a href="@AuthUrl("register")" class="land-btn land-btn-primary d-none d-md-inline-flex" data-testid="land-getstarted">
                @Loc.T("NavGetStarted")
            </a>
        </div>
    </div>
</nav>

@* =========================== HERO =========================== *@
<section class="land-hero" data-testid="land-hero">
    <div class="land-container">
        <div class="land-hero-grid">
            <div>
                @* ===== Live Activity ticker (mock data, JS-rotated every 8s) ===== *@
                <div class="land-live-ticker" data-testid="land-live-ticker" aria-live="polite"
                     data-verb-report="@Loc.T("LiveTickerVerbReport")"
                     data-verb-interp="@Loc.T("LiveTickerVerbInterp")"
                     data-verb-compare="@Loc.T("LiveTickerVerbCompare")"
                     data-verb-risk="@Loc.T("LiveTickerVerbRisk")"
                     data-verb-clinic="@Loc.T("LiveTickerVerbClinic")"
                     data-label-ago="@Loc.T("LiveTickerAgo")"
                     data-label-min="@Loc.T("LiveTickerMin")"
                     data-label-sec="@Loc.T("LiveTickerSec")"
                     data-label-someone="@Loc.T("LiveTickerSomeone")"
                     data-label-from="@Loc.T("LiveTickerFrom")"
                     data-label-clinic="@Loc.T("LiveTickerClinicLoc")">
                    <span class="land-live-badge">
                        <span class="land-live-dot" aria-hidden="true"></span>
                        @Loc.T("LiveTickerLabel")
                    </span>
                    <span class="land-live-text" id="landLiveText">@Loc.T("LiveTickerLoading")</span>
                </div>

                <div class="land-eyebrow-row">
                    <span class="land-eyebrow">@Loc.T("HeroEyebrow")</span>
                    <span class="land-eyebrow land-eyebrow-coral">@Loc.T("HeroEyebrow2")</span>
                </div>
                <h1>@Loc.T("HeroTitle")</h1>
                <div class="land-audience-line" data-testid="hero-audience-line">
                    <i class="fa-solid fa-user-group land-audience-icon" aria-hidden="true"></i>
                    <span>@Loc.T("HeroAudienceLine")</span>
                </div>
                <p class="lead" style="font-size:1.10rem; max-width: 540px;">
                    @Loc.T("HeroLead")
                </p>
                <div class="land-hero-cta">
                    <a href="@AuthUrl("register")" class="land-btn land-btn-accent land-btn-lg"
                       data-testid="hero-cta-primary">
                        @Loc.T("HeroCtaPrimary") &rarr;
                    </a>
                    <a href="#how" class="land-btn land-btn-ghost land-btn-lg" data-testid="hero-cta-secondary">
                        @Loc.T("HeroCtaSecondary")
                    </a>
                </div>
                <div class="land-hero-stats">
                    <div><strong>30+</strong><span>@Loc.T("HeroStatLangs")</span></div>
                    <div><strong>~30s</strong><span>@Loc.T("HeroStatSpeed")</span></div>
                    <div><strong>LOINC</strong><span>@Loc.T("HeroStatLoinc")</span></div>
                </div>
            </div>

            <div class="land-hero-visual-wrap" data-testid="land-hero-visual">
                @* ===== Deck of 4 sample reports — click to bring forward, click front to zoom ===== *@
                <div class="land-deck" data-testid="land-deck">
                    @* Order in DOM = render order; data-pos is the initial logical position
                       (0 = front, 3 = bottom). Front card has zoom button. JS swaps positions on click. *@
                    <div class="land-deck-card" data-pos="0" data-testid="deck-card-cam-clinic"
                         data-caption="@Loc.T("DeckCaptionCamClinic")"
                         aria-label="@Loc.T("DeckCaptionCamClinic")">
                        <img src="~/images/landing-deck/cam-compare-clinic.png"
                             alt="@Loc.T("DeckCaptionCamClinic")"
                             loading="lazy" />
                        <button type="button" class="land-deck-zoom" data-testid="deck-zoom-cam-clinic"
                                aria-label="@Loc.T("DeckZoomLabel")">
                            <i class="fa-solid fa-magnifying-glass-plus" aria-hidden="true"></i>
                        </button>
                        <span class="land-deck-tag">@Loc.T("DeckCaptionCamClinic")</span>
                    </div>
                    <div class="land-deck-card" data-pos="1" data-testid="deck-card-summary"
                         data-caption="@Loc.T("DeckCaptionSummary")"
                         aria-label="@Loc.T("DeckCaptionSummary")">
                        <img src="~/images/landing-deck/interpret-summary.jpg"
                             alt="@Loc.T("DeckCaptionSummary")"
                             loading="lazy" />
                        <button type="button" class="land-deck-zoom" data-testid="deck-zoom-summary"
                                aria-label="@Loc.T("DeckZoomLabel")">
                            <i class="fa-solid fa-magnifying-glass-plus" aria-hidden="true"></i>
                        </button>
                        <span class="land-deck-tag">@Loc.T("DeckCaptionSummary")</span>
                    </div>
                    <div class="land-deck-card" data-pos="2" data-testid="deck-card-cam"
                         data-caption="@Loc.T("DeckCaptionCam")"
                         aria-label="@Loc.T("DeckCaptionCam")">
                        <img src="~/images/landing-deck/cam-compare.jpg"
                             alt="@Loc.T("DeckCaptionCam")"
                             loading="lazy" />
                        <button type="button" class="land-deck-zoom" data-testid="deck-zoom-cam"
                                aria-label="@Loc.T("DeckZoomLabel")">
                            <i class="fa-solid fa-magnifying-glass-plus" aria-hidden="true"></i>
                        </button>
                        <span class="land-deck-tag">@Loc.T("DeckCaptionCam")</span>
                    </div>
                    <div class="land-deck-card" data-pos="3" data-testid="deck-card-graph"
                         data-caption="@Loc.T("DeckCaptionGraph")"
                         aria-label="@Loc.T("DeckCaptionGraph")">
                        <img src="~/images/landing-deck/graph-b2c.jpg"
                             alt="@Loc.T("DeckCaptionGraph")"
                             loading="lazy" />
                        <button type="button" class="land-deck-zoom" data-testid="deck-zoom-graph"
                                aria-label="@Loc.T("DeckZoomLabel")">
                            <i class="fa-solid fa-magnifying-glass-plus" aria-hidden="true"></i>
                        </button>
                        <span class="land-deck-tag">@Loc.T("DeckCaptionGraph")</span>
                    </div>
                    <div class="land-deck-card" data-pos="4" data-testid="deck-card-correlations"
                         data-caption="@Loc.T("DeckCaptionCorrelations")"
                         aria-label="@Loc.T("DeckCaptionCorrelations")">
                        <img src="~/images/landing-deck/interpret-correlations.jpg"
                             alt="@Loc.T("DeckCaptionCorrelations")"
                             loading="lazy" />
                        <button type="button" class="land-deck-zoom" data-testid="deck-zoom-correlations"
                                aria-label="@Loc.T("DeckZoomLabel")">
                            <i class="fa-solid fa-magnifying-glass-plus" aria-hidden="true"></i>
                        </button>
                        <span class="land-deck-tag">@Loc.T("DeckCaptionCorrelations")</span>
                    </div>

                    @* hint pill, only visible until first interaction *@
                    <div class="land-deck-hint" id="landDeckHint" data-testid="deck-hint">
                        <i class="fa-solid fa-hand-pointer" aria-hidden="true"></i>
                        <span>@Loc.T("DeckHint")</span>
                    </div>

                    @* prev/next nav arrows (also keyboard ← →) *@
                    <button type="button" class="land-deck-nav land-deck-nav-prev"
                            id="landDeckPrev" data-testid="deck-nav-prev"
                            aria-label="@Loc.T("DeckPrevLabel")">
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="land-deck-nav land-deck-nav-next"
                            id="landDeckNext" data-testid="deck-nav-next"
                            aria-label="@Loc.T("DeckNextLabel")">
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

@* ===== Zoom modal (one global, populated on click) ===== *@
<div class="land-deck-modal" id="landDeckModal" data-testid="land-deck-modal" hidden>
    <button type="button" class="land-deck-modal-close" id="landDeckModalClose"
            data-testid="land-deck-modal-close" aria-label="@Loc.T("DeckCloseLabel")">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
    </button>
    <figure class="land-deck-modal-figure">
        <img id="landDeckModalImg" src="" alt="" />
        <figcaption id="landDeckModalCaption"></figcaption>
    </figure>
</div>

@* =========================== AUDIENCE PILLARS =========================== *@
<section class="land-section" id="audience" data-testid="land-audience">
    <div class="land-container">
        <div class="text-center mb-5">
            <span class="land-eyebrow">@Loc.T("AudienceEyebrow")</span>
            <h2>@Loc.T("AudienceTitle")</h2>
            <p style="max-width: 640px; margin: 0 auto;">@Loc.T("AudienceLead")</p>
        </div>
        <div class="land-pillars">
            <div class="land-pillar" data-testid="pillar-individuals">
                <div class="land-pillar-head">
                    <div class="land-pillar-icon"><i class="fa-solid fa-user-large" aria-hidden="true"></i></div>
                    <div class="land-pillar-counter" data-testid="pillar-ind-counter">
                        <span class="land-pillar-counter-num"
                              data-count-target="12400"
                              data-count-suffix="+">0</span>
                        <span class="land-pillar-counter-label">@Loc.T("PillarIndCounterLabel")</span>
                    </div>
                </div>
                <h3>@Loc.T("PillarIndTitle")</h3>
                <p>@Loc.T("PillarIndLead")</p>
                <ul>
                    <li>@Loc.T("PillarIndPt1")</li>
                    <li>@Loc.T("PillarIndPt2")</li>
                    <li>@Loc.T("PillarIndPt3")</li>
                    <li>@Loc.T("PillarIndPt4")</li>
                    <li>@Loc.T("PillarIndPt5")</li>
                    <li>@Loc.T("PillarIndPt6")</li>
                    <li>@Loc.T("PillarIndPt7")</li>
                </ul>
                <a href="@AuthUrl("register")" class="land-btn land-btn-ghost mt-3" data-testid="pillar-ind-cta">
                    @Loc.T("PillarIndCta") &rarr;
                </a>
            </div>
            <div class="land-pillar" data-testid="pillar-labs">
                <div class="land-pillar-head">
                    <div class="land-pillar-icon"><i class="fa-solid fa-stethoscope" aria-hidden="true"></i></div>
                    <div class="land-pillar-counter" data-testid="pillar-lab-counter">
                        <span class="land-pillar-counter-num"
                              data-count-target="87"
                              data-count-suffix="+">0</span>
                        <span class="land-pillar-counter-label">@Loc.T("PillarLabCounterLabel")</span>
                    </div>
                </div>
                <h3>@Loc.T("PillarLabTitle")</h3>
                <p>@Loc.T("PillarLabLead")</p>
                <ul>
                    <li class="land-pillar-li-strong">@Loc.T("PillarLabPt0")</li>
                    <li>@Loc.T("PillarLabPt1")</li>
                    <li>@Loc.T("PillarLabPt2")</li>
                    <li>@Loc.T("PillarLabPt3")</li>
                    <li>@Loc.T("PillarLabPt4")</li>
                </ul>
                <span class="land-tooltip-wrap" data-tooltip="@Loc.T("PillarTooltipRegister")">
                    <a href="@AuthUrl("register")" class="land-btn land-btn-ghost mt-3" data-testid="pillar-lab-cta">
                        @Loc.T("PillarLabCta") &rarr;
                    </a>
                </span>
            </div>
            <div class="land-pillar" data-testid="pillar-clinics">
                <div class="land-pillar-head">
                    <div class="land-pillar-icon"><i class="fa-solid fa-hospital" aria-hidden="true"></i></div>
                    <div class="land-pillar-counter" data-testid="pillar-cln-counter">
                        <span class="land-pillar-counter-num"
                              data-count-target="14"
                              data-count-suffix="+">0</span>
                        <span class="land-pillar-counter-label">@Loc.T("PillarClnCounterLabel")</span>
                    </div>
                </div>
                <h3>@Loc.T("PillarClnTitle")</h3>
                <p>@Loc.T("PillarClnLead")</p>
                <ul>
                    <li class="land-pillar-li-strong">@Loc.T("PillarClnPt0")</li>
                    <li>@Loc.T("PillarClnPt1")</li>
                    <li>@Loc.T("PillarClnPt2")</li>
                    <li>@Loc.T("PillarClnPt3")</li>
                    <li>@Loc.T("PillarClnPt4")</li>
                </ul>
                <span class="land-tooltip-wrap" data-tooltip="@Loc.T("PillarTooltipRegister")">
                    <a href="@AuthUrl("register")" class="land-btn land-btn-ghost mt-3" data-testid="pillar-cln-cta">
                        @Loc.T("PillarClnCta") &rarr;
                    </a>
                </span>
            </div>
        </div>
    </div>
</section>

@* =========================== COMPARISON TABLE =========================== *@
<section class="land-section" id="compare" data-testid="land-compare">
    <div class="land-container">
        <div class="text-center mb-5">
            <span class="land-eyebrow">@Loc.T("CompareEyebrow")</span>
            <h2>@Loc.T("CompareTitle")</h2>
            <p style="max-width: 640px; margin: 0 auto;">@Loc.T("CompareLead")</p>
        </div>

        <div class="land-compare" data-testid="compare-table">
            @* ----- Table HEADER (3 provider cards) ----- *@
            <div class="land-compare-head">
                <div class="land-compare-feature-spacer" aria-hidden="true"></div>

                <div class="land-compare-provider land-compare-self" data-testid="compare-col-self">
                    <div class="land-compare-provider-icon">
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                    </div>
                    <h3>@Loc.T("CompareColSelf")</h3>
                    <p>@Loc.T("CompareColSelfSub")</p>
                </div>

                <div class="land-compare-provider land-compare-doctor" data-testid="compare-col-doctor">
                    <div class="land-compare-provider-icon">
                        <i class="fa-solid fa-user-doctor" aria-hidden="true"></i>
                    </div>
                    <h3>@Loc.T("CompareColDoctor")</h3>
                    <p>@Loc.T("CompareColDoctorSub")</p>
                </div>

                <div class="land-compare-provider land-compare-us" data-testid="compare-col-us">
                    <span class="land-compare-best">
                        <i class="fa-solid fa-star" aria-hidden="true"></i>
                        @Loc.T("CompareBestBadge")
                    </span>
                    <div class="land-compare-provider-icon land-compare-us-icon">M+</div>
                    <h3>@Loc.T("CompareColUs")</h3>
                    <p>@Loc.T("CompareColUsSub")</p>
                </div>
            </div>

            @* ----- Table ROWS ----- *@
            @{
                var compareRows = new[]
                {
                    new { Label = "CompareRow1Label", Self = "CompareRow1Self", Doctor = "CompareRow1Doctor", Us = "CompareRow1Us", SelfIcon = "fa-clock", DoctorIcon = "fa-hourglass-half", UsIcon = "fa-bolt" },
                    new { Label = "CompareRow2Label", Self = "CompareRow2Self", Doctor = "CompareRow2Doctor", Us = "CompareRow2Us", SelfIcon = "fa-circle-question", DoctorIcon = "fa-euro-sign", UsIcon = "fa-tag" },
                    new { Label = "CompareRow3Label", Self = "CompareRow3Self", Doctor = "CompareRow3Doctor", Us = "CompareRow3Us", SelfIcon = "fa-circle-question", DoctorIcon = "fa-circle-exclamation", UsIcon = "fa-check" },
                    new { Label = "CompareRow4Label", Self = "CompareRow4Self", Doctor = "CompareRow4Doctor", Us = "CompareRow4Us", SelfIcon = "fa-xmark", DoctorIcon = "fa-pen", UsIcon = "fa-chart-line" },
                    new { Label = "CompareRow5Label", Self = "CompareRow5Self", Doctor = "CompareRow5Doctor", Us = "CompareRow5Us", SelfIcon = "fa-xmark", DoctorIcon = "fa-circle-exclamation", UsIcon = "fa-shield-heart" },
                    new { Label = "CompareRow6Label", Self = "CompareRow6Self", Doctor = "CompareRow6Doctor", Us = "CompareRow6Us", SelfIcon = "fa-check", DoctorIcon = "fa-xmark", UsIcon = "fa-clock-rotate-left" },
                    new { Label = "CompareRow7Label", Self = "CompareRow7Self", Doctor = "CompareRow7Doctor", Us = "CompareRow7Us", SelfIcon = "fa-xmark", DoctorIcon = "fa-circle-exclamation", UsIcon = "fa-users" },
                };
                int rowIdx = 0;
            }
            <div class="land-compare-rows" data-testid="compare-rows">
                @foreach (var r in compareRows)
                {
                    rowIdx++;
                    <div class="land-compare-row" data-testid="compare-row-@rowIdx">
                        <div class="land-compare-feature">@Loc.T(r.Label)</div>
                        <div class="land-compare-cell land-compare-cell-self">
                            <i class="fa-solid @r.SelfIcon" aria-hidden="true"></i>
                            <span>@Loc.T(r.Self)</span>
                        </div>
                        <div class="land-compare-cell land-compare-cell-doctor">
                            <i class="fa-solid @r.DoctorIcon" aria-hidden="true"></i>
                            <span>@Loc.T(r.Doctor)</span>
                        </div>
                        <div class="land-compare-cell land-compare-cell-us">
                            <i class="fa-solid @r.UsIcon" aria-hidden="true"></i>
                            <span>@Loc.T(r.Us)</span>
                        </div>
                    </div>
                }
            </div>

            @* ----- Bottom CTA ----- *@
            <div class="land-compare-cta">
                <a href="@AuthUrl("register")" class="land-btn land-btn-accent land-btn-lg"
                   data-testid="compare-cta">
                    @Loc.T("CompareCta") &rarr;
                </a>
            </div>
        </div>
    </div>
</section>

@* =========================== HOW IT WORKS =========================== *@
<section class="land-section" id="how" style="background: var(--land-surface);" data-testid="land-how">
    <div class="land-container">
        <div class="text-center mb-5">
            <span class="land-eyebrow">@Loc.T("HowEyebrow")</span>
            <h2>@Loc.T("HowTitle")</h2>
        </div>
        <div class="land-steps">
            <div class="land-step">
                <div class="land-step-num">1</div>
                <h3>@Loc.T("HowStep1Title")</h3>
                <p>@Loc.T("HowStep1Body")</p>
            </div>
            <div class="land-step">
                <div class="land-step-num">2</div>
                <h3>@Loc.T("HowStep2Title")</h3>
                <p>@Loc.T("HowStep2Body")</p>
            </div>
            <div class="land-step">
                <div class="land-step-num">3</div>
                <h3>@Loc.T("HowStep3Title")</h3>
                <p>@Loc.T("HowStep3Body")</p>
            </div>
        </div>
    </div>
</section>

@* =========================== FEATURES GRID =========================== *@
<section class="land-section" id="features" data-testid="land-features">
    <div class="land-container">
        <div class="text-center mb-5">
            <span class="land-eyebrow">@Loc.T("FeaturesEyebrow")</span>
            <h2>@Loc.T("FeaturesTitle")</h2>
        </div>
        <div class="land-features">
            <div class="land-feature"><span class="land-feature-icon">🌍</span>
                <h4>@Loc.T("Feat1Title")</h4><p>@Loc.T("Feat1Body")</p></div>
            <div class="land-feature"><span class="land-feature-icon">👨‍👩‍👧</span>
                <h4>@Loc.T("Feat2Title")</h4><p>@Loc.T("Feat2Body")</p></div>
            <div class="land-feature"><span class="land-feature-icon">📈</span>
                <h4>@Loc.T("Feat3Title")</h4><p>@Loc.T("Feat3Body")</p></div>
            <div class="land-feature"><span class="land-feature-icon">⚖️</span>
                <h4>@Loc.T("Feat4Title")</h4><p>@Loc.T("Feat4Body")</p></div>
            <div class="land-feature"><span class="land-feature-icon">🧬</span>
                <h4>@Loc.T("Feat5Title")</h4><p>@Loc.T("Feat5Body")</p></div>
            <div class="land-feature"><span class="land-feature-icon">⚠️</span>
                <h4>@Loc.T("Feat6Title")</h4><p>@Loc.T("Feat6Body")</p></div>
        </div>
    </div>
</section>

@* =========================== PRICING TEASER =========================== *@
<section class="land-section" id="pricing" data-testid="land-pricing-section">
    <div class="land-container">
        <div class="land-pricing">
