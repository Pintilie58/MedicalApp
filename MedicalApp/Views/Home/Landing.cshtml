<script>
(function(){
    // Language dropdown open/close
    var btn = document.getElementById('landLangBtn');
    var menu = document.getElementById('landLangMenu');
    if (btn && menu) {
        btn.addEventListener('click', function(e){
            e.stopPropagation();
            menu.classList.toggle('d-none');
            btn.setAttribute('aria-expanded', menu.classList.contains('d-none') ? 'false' : 'true');
        });
        document.addEventListener('click', function(e){
            if (!menu.contains(e.target) && e.target !== btn) menu.classList.add('d-none');
        });
    }
    // Scroll reveal (intersection observer)
    if ('IntersectionObserver' in window) {
        var els = document.querySelectorAll('.land-reveal');
        var io = new IntersectionObserver(function(entries){
            entries.forEach(function(e){
                if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
            });
        }, { threshold: 0.15 });
        els.forEach(function(el){ io.observe(el); });
    }
    // Animated count-up for pillar counters (fires once per element when visible).
    // Uses requestAnimationFrame + an ease-out curve for a smooth "ramp up" feel.
    if ('IntersectionObserver' in window) {
        var nums = document.querySelectorAll('.land-pillar-counter-num[data-count-target]');
        var nf = (typeof Intl !== 'undefined' && Intl.NumberFormat) ? new Intl.NumberFormat() : null;
        var formatN = function(n) { return nf ? nf.format(n) : String(n); };
        var animate = function(el) {
            var target = parseInt(el.getAttribute('data-count-target'), 10) || 0;
            var suffix = el.getAttribute('data-count-suffix') || '';
            var duration = 1400;
            var start = null;
            var step = function(ts) {
                if (start === null) start = ts;
                var p = Math.min(1, (ts - start) / duration);
                // ease-out cubic
                var eased = 1 - Math.pow(1 - p, 3);
                var val = Math.round(target * eased);
                el.textContent = formatN(val) + suffix;
                if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
        };
        var io2 = new IntersectionObserver(function(entries){
            entries.forEach(function(e){
                if (e.isIntersecting) { animate(e.target); io2.unobserve(e.target); }
            });
        }, { threshold: 0.45 });
        nums.forEach(function(el){ io2.observe(el); });
    }
    // Live activity ticker (Hero) — mock data, one item visible at a time, fades every 8s.
    // The data is intentionally anonymized + plausible so the ticker feels real
    // without claiming any specific patient. Translatable verbs come from data-*
    // attributes so localized phrasings still work.
    (function(){
        var el = document.getElementById('landLiveText');
        if (!el) return;
        var rootEl = el.closest('.land-live-ticker');
        var verbReport     = rootEl ? rootEl.getAttribute('data-verb-report')     : 'received their report in';
        var verbInterp     = rootEl ? rootEl.getAttribute('data-verb-interp')     : 'just got their interpretation in';
        var verbCompare    = rootEl ? rootEl.getAttribute('data-verb-compare')    : 'compared 3 past tests in';
        var verbRisk       = rootEl ? rootEl.getAttribute('data-verb-risk')       : 'discovered a risk factor in';
        var verbClinic     = rootEl ? rootEl.getAttribute('data-verb-clinic')     : 'sent 24 reports in batch from';
        var labelAgo       = rootEl ? rootEl.getAttribute('data-label-ago')       : 'ago';
        var labelMin       = rootEl ? rootEl.getAttribute('data-label-min')       : 'min';
        var labelSec       = rootEl ? rootEl.getAttribute('data-label-sec')       : 'sec';
        var labelSomeone   = rootEl ? rootEl.getAttribute('data-label-someone')   : 'Someone';
        var labelFrom      = rootEl ? rootEl.getAttribute('data-label-from')      : 'from';
        var labelClinicLoc = rootEl ? rootEl.getAttribute('data-label-clinic')    : 'A clinic in';

        // Plausible distribution of Romanian cities (capital first, then big cities)
        var cities = ['București','București','Cluj-Napoca','Timișoara','Iași','Constanța','Brașov','Sibiu','Oradea','Galați','Craiova','Ploiești'];
        var verbs  = [
            { type:'person', verb: verbReport,  unit:'s', range:[18, 38] },
            { type:'person', verb: verbInterp,  unit:'s', range:[22, 34] },
            { type:'person', verb: verbCompare, unit:'s', range:[12, 26] },
            { type:'person', verb: verbRisk,    unit:'s', range:[24, 40] },
            { type:'clinic', verb: verbClinic,  unit:'min', range:[2, 9] }
        ];
        var lastIdx = -1;
        function pick(arr) {
            var i; do { i = Math.floor(Math.random() * arr.length); } while (arr.length > 1 && i === lastIdx);
            lastIdx = i; return arr[i];
        }
        function buildText() {
            var v = pick(verbs);
            var city = cities[Math.floor(Math.random() * cities.length)];
            var n = Math.floor(v.range[0] + Math.random() * (v.range[1] - v.range[0] + 1));
            var ago = Math.floor(1 + Math.random() * 9);
            var subject = v.type === 'clinic' ? (labelClinicLoc + ' ' + city) : (labelSomeone + ' ' + labelFrom + ' ' + city);
            var unitLabel = v.unit === 's' ? labelSec : labelMin;
            return subject + ' ' + v.verb + ' ' + n + unitLabel + ' · ' + ago + ' ' + labelMin + ' ' + labelAgo;
        }
        function rotate() {
            el.classList.add('is-fading');
            setTimeout(function(){
                el.textContent = buildText();
                el.classList.remove('is-fading');
            }, 280);
        }
        // First message shown immediately, then rotate every 8s.
        el.textContent = buildText();
        setInterval(rotate, 8000);
    })();
    // ===== Deck of cards in Hero (4 sample reports) =====
    // - Click on any card brings it to the front, others shuffle back one position.
    // - The 🔍 button on the FRONT card opens a zoom modal (lightbox).
    // - The hint pill auto-hides on first interaction.
    (function(){
        var deck = document.querySelector('.land-deck');
        if (!deck) return;
        var cards = Array.prototype.slice.call(deck.querySelectorAll('.land-deck-card'));
        var hint  = document.getElementById('landDeckHint');
        var modal = document.getElementById('landDeckModal');
        var mImg  = document.getElementById('landDeckModalImg');
        var mCap  = document.getElementById('landDeckModalCaption');
        var mClose= document.getElementById('landDeckModalClose');

        // Each card carries data-pos; the value is the layer ordering (0 = front, N-1 = bottom).
        // We rotate positions so the clicked card always becomes 0 and the rest fill 1..N-1.
        function bringToFront(targetCard) {
            var targetPos = parseInt(targetCard.getAttribute('data-pos'), 10);
            if (targetPos === 0) return false; // already front
            cards.forEach(function(c){
                var p = parseInt(c.getAttribute('data-pos'), 10);
                if (c === targetCard) {
                    c.setAttribute('data-pos', '0');
                } else if (p < targetPos) {
                    // Cards previously in front of the target get pushed back by one.
                    c.setAttribute('data-pos', String(p + 1));
                }
                // Cards already behind the target keep their position.
            });
            return true;
        }
        function hideHint() { if (hint) hint.classList.add('is-hidden'); }
        // Navigate the deck "next" (› = top card slides to back; the second card comes up).
        // Uses modulo over the number of cards in the deck (currently 5) so the loop
        // works regardless of how many cards we add in the future.
        function navNext() {
            var n = cards.length;
            cards.forEach(function(c){
                var p = parseInt(c.getAttribute('data-pos'), 10);
                c.setAttribute('data-pos', String((p - 1 + n) % n));
            });
        }
        // Navigate the deck "prev" (‹ = back card jumps to the front; everyone else moves back).
        function navPrev() {
            var n = cards.length;
            cards.forEach(function(c){
                var p = parseInt(c.getAttribute('data-pos'), 10);
                c.setAttribute('data-pos', String((p + 1) % n));
            });
        }
        function openModal(card) {
            if (!modal) return;
            var img = card.querySelector('img');
            mImg.src = img ? img.getAttribute('src') : '';
            mImg.alt = img ? (img.getAttribute('alt') || '') : '';
            mCap.textContent = card.getAttribute('data-caption') || '';
            modal.hidden = false;
            // Force reflow so the CSS transition kicks in
            void modal.offsetWidth;
            modal.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() {
            if (!modal) return;
            modal.classList.remove('is-open');
            document.body.style.overflow = '';
            setTimeout(function(){ modal.hidden = true; mImg.src = ''; }, 220);
        }

        cards.forEach(function(card){
            // Click on the card body (not on the zoom button) -> bring to front.
            // If already front, ignore (the zoom button handles the modal).
            card.addEventListener('click', function(e){
                if (e.target.closest('.land-deck-zoom')) return; // handled below
                hideHint();
                bringToFront(card);
            });
        });
        // Zoom buttons (one per card) — only act when their card is the front one.
        deck.querySelectorAll('.land-deck-zoom').forEach(function(btn){
            btn.addEventListener('click', function(e){
                e.stopPropagation();
                var card = btn.closest('.land-deck-card');
                if (!card) return;
                if (parseInt(card.getAttribute('data-pos'), 10) !== 0) {
                    bringToFront(card);
                    return;
                }
                hideHint();
                openModal(card);
            });
        });

        if (mClose) mClose.addEventListener('click', closeModal);
        if (modal) modal.addEventListener('click', function(e){
            // Click on backdrop (outside the figure) closes
            if (e.target === modal) closeModal();
        });
        // Deck nav arrows (prev / next) + click-then-deal animation
        var btnPrev = document.getElementById('landDeckPrev');
        var btnNext = document.getElementById('landDeckNext');
        if (btnPrev) btnPrev.addEventListener('click', function(e){ e.stopPropagation(); hideHint(); navPrev(); });
        if (btnNext) btnNext.addEventListener('click', function(e){ e.stopPropagation(); hideHint(); navNext(); });

        // Keyboard nav: ← → when the deck (or any of its children) is focused/hovered.
        // We hook on the deck element so it doesn't hijack arrow keys while the user
        // is scrolling the page or typing somewhere else.
        // Make the deck focusable so :focus-within actually fires.
        deck.setAttribute('tabindex', '0');
        var deckHover = false;
        deck.addEventListener('mouseenter', function(){ deckHover = true;  });
        deck.addEventListener('mouseleave', function(){ deckHover = false; });
        document.addEventListener('keydown', function(e){
            if (e.key === 'Escape' && modal && modal.classList.contains('is-open')) {
                closeModal();
                return;
            }
            // Only catch ← / → if the user is hovering the deck OR has it focused.
            var active = document.activeElement;
            var deckFocused = active && (active === deck || deck.contains(active));
            if (!deckHover && !deckFocused) return;
            if (modal && modal.classList.contains('is-open')) return;
            if (e.key === 'ArrowRight') { e.preventDefault(); hideHint(); navNext(); }
            else if (e.key === 'ArrowLeft') { e.preventDefault(); hideHint(); navPrev(); }
        });
    })();
    // Smooth anchor scroll
    document.querySelectorAll('a[href^="#"]').forEach(function(a){
        a.addEventListener('click', function(e){
            var href = a.getAttribute('href');
            if (href === '#' || href.length < 2) return;
            var target = document.querySelector(href);
            if (target) {
                e.preventDefault();
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
})();
</script>

</body>
