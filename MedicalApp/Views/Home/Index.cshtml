@{
    ViewData["Title"] = Loc.T("AppTitle");
    var loginModel = ViewData["LoginModel"] as LoginViewModel ?? new LoginViewModel();
    var registerModel = ViewData["RegisterModel"] as RegisterViewModel ?? new RegisterViewModel();
    var activeTab = (ViewData["ActiveTab"] as string) ?? (TempData["ActiveTab"] as string) ?? "login";
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

    // ?flow=free — set by /Home/Auth when the visitor clicks a "free
    // interpretation" CTA on the landing page (HeroCtaPrimary, PillarIndCta,
    // CompareCta, PricingCta). In that branch the Register form must:
    //   1. Force UserType=Individual (checked + only radio rendered)
    //   2. Hide the Clinic radio option entirely so the user can't switch
    //   3. Skip the Clinic-only extra fields (name / city / address)
    //   4. Carry a hidden <input name="flow" value="free"> so AccountController
    //      can enforce the same policy defensively on POST.
    // The Login tab and header nav are NOT affected by this flag.
    var isFreeFlow = string.Equals(ViewData["Flow"] as string, "free", System.StringComparison.OrdinalIgnoreCase);
    if (isFreeFlow) { registerModel.UserType = "Individual"; }
}

<link rel="stylesheet" href="~/css/password-complexity.css" asp-append-version="true" />

<div class="container py-4">

    <!-- Language selector — flag + name, prominent enough to spot at a glance -->
    <div class="d-flex justify-content-end mb-3">
        <form asp-controller="Home" asp-action="SetLanguage" method="post" class="d-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <label class="form-label m-0 small text-muted">@Loc.T("SelectLanguage"):</label>
            <select name="culture" class="form-select" style="width:auto; min-width: 180px; font-weight:600; border-color:#0d6efd;"
                    onchange="this.form.submit()" data-testid="auth-lang-select">
                @* Source of truth: SupportedLanguagesConfig.All — adding a
                   language to that C# file automatically renders it here. *@
                @foreach (var l in MedicalApp.Services.SupportedLanguagesConfig.All)
                {
                    <option value="@l.Code" selected="@(currentCulture == l.Code)">@l.FlagEmoji&nbsp; @l.NativeName</option>
                }
            </select>
        </form>
    </div>

    <div class="row g-4 align-items-stretch">

        <!-- Welcome image + message -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0">
                <img src="~/images/welcome.jpg" class="card-img-top" alt="Welcome"
                     onerror="this.onerror=null;this.src='https://via.placeholder.com/800x500/0d6efd/ffffff?text=MyMedicalApp.NET';" />
                <div class="card-body text-center">
                    <h2 class="card-title fw-bold text-primary mb-3" data-testid="welcome-heading">
                        @Loc.T("WelcomeMessage")
                    </h2>
                    <p class="fs-5 fw-semibold text-success mb-1" data-testid="welcome-tagline-1">
                        @Loc.T("WelcomeTagline1")
                    </p>
                    <p class="fs-5 fw-semibold text-success mb-1" data-testid="welcome-tagline-2">
                        @Loc.T("WelcomeTagline2")
                    </p>
                    <p class="fs-6 text-secondary mb-0" data-testid="welcome-tagline-3">
                        @Loc.T("WelcomeTagline3")
                    </p>
                </div>
            </div>
        </div>

        <!-- Auth panel -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success">@successMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "login" ? "active" : "")"
                                    data-bs-toggle="tab" data-bs-target="#loginPane" type="button">
                                @Loc.T("Login")
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "register" ? "active" : "")"
                                    data-bs-toggle="tab" data-bs-target="#registerPane" type="button">
                                @Loc.T("Register")
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <!-- Login Form -->
                        <div id="loginPane" class="tab-pane fade @(activeTab == "login" ? "show active" : "")">
                            <form asp-controller="Account" asp-action="Login" method="post" autocomplete="on">
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                <div class="mb-3">
                                    <label asp-for="@loginModel.Email" class="form-label">@Loc.T("Email")</label>
                                    <input asp-for="@loginModel.Email" name="Email" type="email" class="form-control" autocomplete="username" />
                                    <span asp-validation-for="@loginModel.Email" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@loginModel.Parola" class="form-label">@Loc.T("Password")</label>
                                    <input asp-for="@loginModel.Parola" name="Parola" type="password" class="form-control" autocomplete="current-password" value="" />
                                    <span asp-validation-for="@loginModel.Parola" class="text-danger small"></span>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">@Loc.T("LoginButton")</button>
                                <div class="text-end mt-2">
                                    <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none small text-muted">
                                        @Loc.T("ForgotPassword")
                                    </a>
                                </div>
                            </form>
                        </div>

                        <!-- Register Form -->
                        <div id="registerPane" class="tab-pane fade @(activeTab == "register" ? "show active" : "")">
                            <form asp-controller="Account" asp-action="Register" method="post" autocomplete="off">
                                @Html.AntiForgeryToken()
                                @* Preserved from ?flow=free query param — see HomeController.Auth + AccountController.Register. *@
                                @if (isFreeFlow)
                                {
                                    <input type="hidden" name="flow" value="free" data-testid="register-flow-free" />
                                }
                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                @* CAM: tip cont — Persoană fizică vs. Clinică Analize Medicale.
                                   When isFreeFlow==true (visitor came from a "free interpretation"
                                   CTA), the Clinic radio is hidden and the whole group collapses to
                                   a single Individual pill — B2B signup is blocked for that flow. *@
                                <div class="mb-3" data-testid="register-usertype-group">
                                    <label class="form-label fw-semibold">@Loc.T("UserTypeLabel")</label>
                                    <div class="btn-group w-100" role="group" aria-label="User type">
                                        <input type="radio" class="btn-check" name="UserType" id="userTypeIndividual"
                                               value="Individual" autocomplete="off"
                                               @(isFreeFlow || !string.Equals(registerModel.UserType, "Clinic", System.StringComparison.OrdinalIgnoreCase) ? "checked" : "")
                                               data-testid="register-usertype-individual" />
                                        <label class="btn btn-outline-primary" for="userTypeIndividual">
                                            &#128106; @Loc.T("UserTypeIndividual")
                                        </label>

                                        @if (!isFreeFlow)
                                        {
                                            <input type="radio" class="btn-check" name="UserType" id="userTypeClinic"
                                                   value="Clinic" autocomplete="off"
                                                   @(string.Equals(registerModel.UserType, "Clinic", System.StringComparison.OrdinalIgnoreCase) ? "checked" : "")
                                                   data-testid="register-usertype-clinic" />
                                            <label class="btn btn-outline-primary" for="userTypeClinic">
                                                &#127973; @Loc.T("UserTypeClinic")
                                            </label>
                                        }
                                    </div>
                                </div>

                                @* CAM: câmpurile suplimentare pentru clinică — vizibile doar când UserType=Clinic *@
                                <div id="clinicFields" style="display:@(string.Equals(registerModel.UserType, "Clinic", StringComparison.OrdinalIgnoreCase) ? "block" : "none");">
                                    <div class="alert alert-info py-2 small mb-3" data-testid="register-clinic-gdpr-note">
                                        &#9888; @Loc.T("RegisterClinicGdprNote")
                                        <div class="mt-2 d-flex align-items-start gap-2" data-testid="register-clinic-windows-note">
                                            <i class="bi bi-windows" style="color:#0078D4; font-size:1.1rem;" aria-hidden="true"></i>
                                            <span>
                                                @Html.Raw(Loc.T("RegisterClinicWindowsOnlyHtmlFmt"))
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="@registerModel.ClinicName" class="form-label">@Loc.T("ClinicNameLabel")</label>
                                        <input asp-for="@registerModel.ClinicName" name="ClinicName" class="form-control"
                                               autocomplete="off" data-testid="register-clinic-name" />
                                        <span asp-validation-for="@registerModel.ClinicName" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="@registerModel.ClinicCity" class="form-label">@Loc.T("ClinicCityLabel")</label>
                                        <input asp-for="@registerModel.ClinicCity" name="ClinicCity" class="form-control"
                                               autocomplete="off" data-testid="register-clinic-city" />
                                        <span asp-validation-for="@registerModel.ClinicCity" class="text-danger small"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="@registerModel.ClinicAddress" class="form-label">@Loc.T("ClinicAddressLabel")</label>
                                        <input asp-for="@registerModel.ClinicAddress" name="ClinicAddress" class="form-control"
                                               autocomplete="off" data-testid="register-clinic-address" />
                                        <span asp-validation-for="@registerModel.ClinicAddress" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="@registerModel.Email" class="form-label">@Loc.T("Email")</label>
                                    <input asp-for="@registerModel.Email" name="Email" class="form-control" autocomplete="off" />
                                    <span asp-validation-for="@registerModel.Email" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.Parola" class="form-label">@Loc.T("Password")</label>
                                    <input asp-for="@registerModel.Parola" name="Parola" type="password" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="@registerModel.Parola" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.ConfirmParola" class="form-label">@Loc.T("ConfirmPassword")</label>
                                    <input asp-for="@registerModel.ConfirmParola" name="ConfirmParola" type="password" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="@registerModel.ConfirmParola" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.PromoCode" class="form-label">@Loc.T("PromoCodeOptional")</label>
                                    <input asp-for="@registerModel.PromoCode" name="PromoCode" id="promoCodeInput" class="form-control font-monospace" autocomplete="off" placeholder="@Loc.T("PromoCodePlaceholder")" />
                                    <span asp-validation-for="@registerModel.PromoCode" class="text-danger small"></span>
                                    <div id="promoCodeFeedback" class="form-text">@Loc.T("PromoCodeHint")</div>
                                </div>
                                <button type="submit" class="btn btn-success w-100">@Loc.T("RegisterButton")</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/password-complexity.js" asp-append-version="true"></script>
    <script>
        // ----- Force-clear PASSWORD fields on page load (bypasses browser autofill of password) -----
        // Email is intentionally LEFT INTACT so the browser remembers the user's email
        // address across visits, while always asking for a fresh password each time.
        window.addEventListener('pageshow', function () {
            var ids = ['loginPane', 'registerPane'];
            ids.forEach(function (paneId) {
                var pane = document.getElementById(paneId);
                if (!pane) return;
                var inputs = pane.querySelectorAll('input[type="password"]');
                inputs.forEach(function (i) { i.value = ''; });
            });
        });
    </script>
    <script>
        // ----- Live promo code validation on register form -----
        (function () {
            var input = document.getElementById('promoCodeInput');
            var feedback = document.getElementById('promoCodeFeedback');
            if (!input || !feedback) return;

            // Detect current UI language from <html lang="...">,
            // fallback to .AspNetCore.Culture cookie, fallback to "en".
            function getLang() {
                var htmlLang = document.documentElement.getAttribute('lang');
                if (htmlLang) return htmlLang.substring(0, 2).toLowerCase();
                var m = document.cookie.match(/\.AspNetCore\.Culture=c%3D([a-zA-Z\-]+)/);
                if (m) return m[1].substring(0, 2).toLowerCase();
                return 'en';
            }

            var defaultText = feedback.textContent;
            var defaultClass = 'form-text';
            var debounceTimer = null;
            var lastChecked = '';

            function setNeutral() {
                feedback.className = defaultClass;
                feedback.textContent = defaultText;
            }

            function setValid(message) {
                feedback.className = 'form-text text-success fw-semibold';
                feedback.textContent = message;
            }

            function setInvalid(message) {
                feedback.className = 'form-text text-danger fw-semibold';
                feedback.textContent = message;
            }

            input.addEventListener('input', function () {
                var value = input.value.trim();
                clearTimeout(debounceTimer);

                if (value === '') { setNeutral(); lastChecked = ''; return; }
                if (value === lastChecked) return;

                debounceTimer = setTimeout(function () {
                    lastChecked = value;
                    var url = '/Account/CheckPromoCode?code=' + encodeURIComponent(value)
                              + '&lang=' + encodeURIComponent(getLang());
                    fetch(url, { credentials: 'same-origin' })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (input.value.trim() !== value) return; // user kept typing
                            if (data.valid) setValid(data.message);
                            else setInvalid(data.message);
                        })
                        .catch(function () { /* keep neutral on network error */ });
                }, 350);
            });
        })();

        // CAM: arată/ascunde câmpurile clinică în funcție de tipul de cont selectat.
        (function () {
            var rIndividual = document.getElementById('userTypeIndividual');
            var rClinic = document.getElementById('userTypeClinic');
            var clinicFields = document.getElementById('clinicFields');
            if (!rIndividual || !rClinic || !clinicFields) return;
            function refresh() {
                clinicFields.style.display = rClinic.checked ? 'block' : 'none';
            }
            rIndividual.addEventListener('change', refresh);
            rClinic.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}
