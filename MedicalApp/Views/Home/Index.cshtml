@{
    ViewData["Title"] = Loc.T("AppTitle");
    var loginModel = ViewData["LoginModel"] as LoginViewModel ?? new LoginViewModel();
    var registerModel = ViewData["RegisterModel"] as RegisterViewModel ?? new RegisterViewModel();
    var activeTab = (ViewData["ActiveTab"] as string) ?? (TempData["ActiveTab"] as string) ?? "login";
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<div class="container py-4">

    <!-- Language selector -->
    <div class="d-flex justify-content-end mb-3">
        <form asp-controller="Home" asp-action="SetLanguage" method="post" class="d-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <label class="form-label m-0 small text-muted">@Loc.T("SelectLanguage"):</label>
            <select name="culture" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
                <option value="en" selected="@(currentCulture == "en")">@Loc.T("English")</option>
                <option value="ro" selected="@(currentCulture == "ro")">@Loc.T("Romanian")</option>
                <option value="fr" selected="@(currentCulture == "fr")">@Loc.T("French")</option>
                <option value="es" selected="@(currentCulture == "es")">@Loc.T("Spanish")</option>
                <option value="de" selected="@(currentCulture == "de")">@Loc.T("German")</option>
            </select>
        </form>
    </div>

    <div class="row g-4 align-items-stretch">

        <!-- Welcome image + message -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0">
                <img src="~/images/welcome.jpg" class="card-img-top" alt="Welcome"
                     onerror="this.onerror=null;this.src='https://via.placeholder.com/800x500/0d6efd/ffffff?text=MedicalApp';" />
                <div class="card-body text-center">
                    <h2 class="card-title fw-bold text-primary">@Loc.T("WelcomeMessage")</h2>
                </div>
            </div>
        </div>

        <!-- Auth panel -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success">@successMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "login" ? "active" : "")"
                                    data-bs-toggle="tab" data-bs-target="#loginPane" type="button">
                                @Loc.T("Login")
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "register" ? "active" : "")"
                                    data-bs-toggle="tab" data-bs-target="#registerPane" type="button">
                                @Loc.T("Register")
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <!-- Login Form -->
                        <div id="loginPane" class="tab-pane fade @(activeTab == "login" ? "show active" : "")">
                            <form asp-controller="Account" asp-action="Login" method="post" autocomplete="off">
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                <div class="mb-3">
                                    <label asp-for="@loginModel.Email" class="form-label">@Loc.T("Email")</label>
                                    <input asp-for="@loginModel.Email" name="Email" class="form-control" autocomplete="off" value="" />
                                    <span asp-validation-for="@loginModel.Email" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@loginModel.Parola" class="form-label">@Loc.T("Password")</label>
                                    <input asp-for="@loginModel.Parola" name="Parola" type="password" class="form-control" autocomplete="new-password" value="" />
                                    <span asp-validation-for="@loginModel.Parola" class="text-danger small"></span>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">@Loc.T("LoginButton")</button>
                                <div class="text-end mt-2">
                                    <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none small text-muted">
                                        @Loc.T("ForgotPassword")
                                    </a>
                                </div>
                            </form>
                        </div>

                        <!-- Register Form -->
                        <div id="registerPane" class="tab-pane fade @(activeTab == "register" ? "show active" : "")">
                            <form asp-controller="Account" asp-action="Register" method="post" autocomplete="off">
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                                <div class="mb-3">
                                    <label asp-for="@registerModel.Email" class="form-label">@Loc.T("Email")</label>
                                    <input asp-for="@registerModel.Email" name="Email" class="form-control" autocomplete="off" />
                                    <span asp-validation-for="@registerModel.Email" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.Parola" class="form-label">@Loc.T("Password")</label>
                                    <input asp-for="@registerModel.Parola" name="Parola" type="password" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="@registerModel.Parola" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.ConfirmParola" class="form-label">@Loc.T("ConfirmPassword")</label>
                                    <input asp-for="@registerModel.ConfirmParola" name="ConfirmParola" type="password" class="form-control" autocomplete="new-password" />
                                    <span asp-validation-for="@registerModel.ConfirmParola" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="@registerModel.PromoCode" class="form-label">@Loc.T("PromoCodeOptional")</label>
                                    <input asp-for="@registerModel.PromoCode" name="PromoCode" id="promoCodeInput" class="form-control font-monospace" autocomplete="off" placeholder="@Loc.T("PromoCodePlaceholder")" />
                                    <span asp-validation-for="@registerModel.PromoCode" class="text-danger small"></span>
                                    <div id="promoCodeFeedback" class="form-text">@Loc.T("PromoCodeHint")</div>
                                </div>
                                <button type="submit" class="btn btn-success w-100">@Loc.T("RegisterButton")</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        // ----- Force-clear login/register fields on page load (bypasses browser autofill) -----
        window.addEventListener('pageshow', function () {
            var ids = ['loginPane', 'registerPane'];
            ids.forEach(function (paneId) {
                var pane = document.getElementById(paneId);
                if (!pane) return;
                var inputs = pane.querySelectorAll('input[type="text"], input[type="email"], input[type="password"], input:not([type])');
                inputs.forEach(function (i) { i.value = ''; });
            });
        });
    </script>
    <script>
        // ----- Live promo code validation on register form -----
        (function () {
            var input = document.getElementById('promoCodeInput');
            var feedback = document.getElementById('promoCodeFeedback');
            if (!input || !feedback) return;

            // Detect current UI language from <html lang="...">,
            // fallback to .AspNetCore.Culture cookie, fallback to "en".
            function getLang() {
                var htmlLang = document.documentElement.getAttribute('lang');
                if (htmlLang) return htmlLang.substring(0, 2).toLowerCase();
                var m = document.cookie.match(/\.AspNetCore\.Culture=c%3D([a-zA-Z\-]+)/);
                if (m) return m[1].substring(0, 2).toLowerCase();
                return 'en';
            }

            var defaultText = feedback.textContent;
            var defaultClass = 'form-text';
            var debounceTimer = null;
            var lastChecked = '';

            function setNeutral() {
                feedback.className = defaultClass;
                feedback.textContent = defaultText;
            }

            function setValid(message) {
                feedback.className = 'form-text text-success fw-semibold';
                feedback.textContent = message;
            }

            function setInvalid(message) {
                feedback.className = 'form-text text-danger fw-semibold';
                feedback.textContent = message;
            }

            input.addEventListener('input', function () {
                var value = input.value.trim();
                clearTimeout(debounceTimer);

                if (value === '') { setNeutral(); lastChecked = ''; return; }
                if (value === lastChecked) return;

                debounceTimer = setTimeout(function () {
                    lastChecked = value;
                    var url = '/Account/CheckPromoCode?code=' + encodeURIComponent(value)
                              + '&lang=' + encodeURIComponent(getLang());
                    fetch(url, { credentials: 'same-origin' })
                        .then(function (r) { return r.json(); })
                        .then(function (data) {
                            if (input.value.trim() !== value) return; // user kept typing
                            if (data.valid) setValid(data.message);
                            else setInvalid(data.message);
                        })
                        .catch(function () { /* keep neutral on network error */ });
                }, 350);
            });
        })();
    </script>
}
