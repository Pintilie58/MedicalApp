@model MedicalApp.Models.InterpretationUploadViewModel
@{
    ViewData["Title"] = Loc.T("InterpretTitle");
    var creditRest = (int)(ViewBag.CreditRest ?? 0);
    var errorMessage = TempData["ErrorMessage"] as string;
    var hasErrors = !ViewData.ModelState.IsValid;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="text-center mb-4">
                <h2 class="text-primary fw-bold">@Loc.T("InterpretTitle")</h2>
                <p class="text-muted">@Loc.T("InterpretIntro")</p>
            </div>

            <div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <strong>@Loc.T("PaidCreditsLabel"):</strong> @ViewBag.CreditRest
                    &nbsp;|&nbsp;
                    <strong>@Loc.T("BonusCreditsLabel"):</strong> @ViewBag.BonusCreditsRemaining
                    &nbsp;|&nbsp;
                    <strong>@Loc.T("TotalAvailableLabel"):</strong>
                    <span class="fw-bold text-success">@ViewBag.TotalAvailableCredits</span>
                </div>
                <small class="text-muted">@Loc.T("OneCreditPerInterpretation")</small>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (hasErrors)
            {
                <div class="alert alert-danger">
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
                        @Html.AntiForgeryToken()

                        <!-- Step 1: Profile selection -->
                        <div class="mb-4">
                            <label asp-for="ProfileId" class="form-label fw-semibold">
                                &#128106; @Loc.T("InterpretWhoForLabel")
                            </label>
                            <div class="input-group profile-select-group">
                                <select asp-for="ProfileId" class="form-select form-select-lg profile-select-input"
                                        data-testid="interpret-profile-select" required>
                                    <option value="">@Loc.T("InterpretSelectProfilePlaceholder")</option>
                                    @foreach (var p in Model.AvailableProfiles)
                                    {
                                        <option value="@p.Id">
                                            @p.Name@(p.IsDefault ? Loc.T("ProfileDefaultSuffix") : "")
                                        </option>
                                    }
                                </select>
                                <a asp-controller="Profiles" asp-action="Create"
                                   class="btn btn-outline-primary"
                                   title="@Loc.T("InterpretAddProfileBtnTooltip")"
                                   data-testid="interpret-add-profile-btn">
                                    &#43; @Loc.T("InterpretAddProfileBtn")
                                </a>
                            </div>
                            <span asp-validation-for="ProfileId" class="text-danger small"></span>
                            <div class="form-text">
                                @Loc.T("InterpretProfileHelp")
                            </div>
                        </div>

                        <!-- Step 2: PDF upload (custom localized file input — the native
                             "Choose File / No file chosen" text comes from the browser and
                             cannot be translated, so we hide it and show our own UI). -->
                        <div class="mb-3">
                            <label asp-for="PdfFile" class="form-label fw-semibold">@Loc.T("SelectPdfFile")</label>
                            <div class="custom-file-input-wrap" data-dnd-target="pdf">
                                <input asp-for="PdfFile" type="file" accept="application/pdf,.pdf"
                                       class="custom-file-input-native" id="pdfFileInput" required />
                                <label for="pdfFileInput" class="btn btn-outline-primary custom-file-input-btn"
                                       data-testid="upload-file-choose-btn">
                                    &#128206; @Loc.T("UploadFileChooseBtn")
                                </label>
                                <span class="custom-file-input-name" id="pdfFileName"
                                      data-empty-text="@Loc.T("UploadFileNoFileChosen")"
                                      data-testid="upload-file-name">
                                    @Loc.T("UploadFileNoFileChosen")
                                </span>
                                @* Small inline hint — visible only on desktop where drag-and-drop
                                   is meaningful. Progressive enhancement: if drag-drop.js fails to
                                   load, the hint still shows harmlessly (no functionality lost). *@
                                <span class="dnd-hint" data-testid="upload-dnd-hint">@Loc.T("DragDropHint")</span>
                            </div>
                            <div class="form-text">@Loc.T("MaxSizeHint")</div>
                            <span asp-validation-for="PdfFile" class="text-danger small"></span>
                        </div>

                        <!-- Submit button — placed directly under the upload box for
                             quicker "select file → interpret" flow (Feb 2026 UX tweak). -->
                        <button type="submit" class="btn btn-primary w-100 btn-lg mt-2" id="submitBtn">
                            @Loc.T("InterpretAndSend")
                        </button>

                        <div class="alert alert-warning small mt-3">
                            <i class="bi bi-info-circle"></i>
                            <strong>@Loc.T("ProcessingNoticeTitle")</strong><br />
                            @Loc.T("ProcessingNoticeBody")
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Account" asp-action="Dashboard" class="text-decoration-none small text-muted">
                    &larr; @Loc.T("BackToDashboard")
                </a>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================= -->
<!-- Full-screen processing overlay - shown on submit,              -->
<!-- automatically disappears when the server redirects (new page). -->
<!-- ============================================================= -->
<div id="processingOverlay" class="processing-overlay" aria-hidden="true" role="status" aria-live="polite">
    <div class="processing-box">
        <h3 class="processing-title">@Loc.T("PleaseWaitFewSeconds")</h3>
        @{
            var uploadMascotVd = new ViewDataDictionary(ViewData)
            {
                ["Mode"] = "waiting",
                ["Size"] = "medium",
                ["StageId"] = "uploadWaitMascot",
                ["TestId"] = "upload-wait-mascot"
            };
        }
        <partial name="_DoctorMascot" view-data="uploadMascotVd" />
        <p class="processing-subtitle">@Loc.T("PleaseWaitDoNotClose")</p>
    </div>
</div>

<style>
    /* Hover & focus highlight for the "Pentru cine este analiza?" profile selector. */
    .profile-select-input {
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
        cursor: pointer;
    }
    .profile-select-input:hover {
        border-color: #0d6efd;
        background-color: #f0f7ff;
        box-shadow: 0 0 0 0.18rem rgba(13, 110, 253, 0.18);
    }
    .profile-select-input:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    /* === Custom localized file input (hides native "Choose File / No file chosen") ===
       Feb 2026: enlarged ~3× into a proper drop zone and made the empty-state
       placeholder red so it functions as a visible "you haven't picked anything"
       warning. Once a file IS selected, the filename displays in normal accent
       colour (see .has-file). */
    .custom-file-input-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
        padding: 32px 20px;
        min-height: 140px;                 /* ≈ 3× the previous ~48px */
        border: 2px dashed #ced4da;        /* dashed to signal "drop here" affordance */
        border-radius: 10px;
        background-color: #fff;
        transition: border-color 0.2s ease, box-shadow 0.2s ease,
                    background-color 0.2s ease;
    }
    .custom-file-input-wrap:hover {
        border-color: #0d6efd;
        background-color: #f8fbff;
        box-shadow: 0 0 0 0.18rem rgba(13, 110, 253, 0.10);
    }
    .custom-file-input-wrap:focus-within {
        border-color: #0d6efd;
        border-style: solid;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    /* Hide the native input but keep it accessible & required-validatable. */
    .custom-file-input-native {
        position: absolute !important;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
        opacity: 0;
    }
    .custom-file-input-btn {
        margin-bottom: 0;
        cursor: pointer;
        white-space: nowrap;
        font-weight: 600;
    }
    /* Empty-state placeholder ("Niciun fișier selectat") — red bold single-line
       so the user can't miss that no file has been picked yet. */
    .custom-file-input-name {
        flex: 0 1 auto;
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.95rem;
        color: #dc3545;                    /* Bootstrap danger */
        font-weight: 600;
    }
    /* File chosen → switch to informative accent colour, not a warning. */
    .custom-file-input-name.has-file {
        color: #0d47a1;
        font-weight: 500;
    }

    .processing-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 2000;
        background: rgba(13, 71, 161, 0.85);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.25s ease-out;
    }

        .processing-overlay.is-visible {
            display: flex;
        }

    .processing-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 40px 48px;
        text-align: center;
        max-width: 440px;
        width: calc(100% - 40px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    .processing-title {
        color: #0d47a1;
        font-weight: 700;
        margin: 0 0 12px 0;
        font-size: 1.5rem;
    }

    .processing-subtitle {
        color: #546e7a;
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@section Scripts {
    <script>
        // === Custom file input — update visible filename on selection ===
        (function () {
            var input = document.getElementById('pdfFileInput');
            var nameEl = document.getElementById('pdfFileName');
            if (!input || !nameEl) return;
            var emptyText = nameEl.getAttribute('data-empty-text') || '';
            // Localized native "required" validation message (replaces the
            // browser-default "Please select a file." which always renders
            // in English on Chromium/Edge regardless of the page language).
            var requiredMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Loc.T("UploadFilePleaseSelect")));
            input.addEventListener('invalid', function () {
                input.setCustomValidity(requiredMsg);
            });
            input.addEventListener('change', function () {
                input.setCustomValidity(''); // clear any previous custom message
                if (input.files && input.files.length > 0) {
                    nameEl.textContent = input.files[0].name;
                    nameEl.classList.add('has-file');
                } else {
                    nameEl.textContent = emptyText;
                    nameEl.classList.remove('has-file');
                }
            });
        })();
    </script>

    <script>
        (function () {
            var form = document.getElementById('uploadForm');
            var btn = document.getElementById('submitBtn');
            var overlay = document.getElementById('processingOverlay');
            if (!form || !overlay) return;

            form.addEventListener('submit', function (e) {
                // Let browser validation (required file) run first.
                if (!form.checkValidity()) return;

                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML = '@Loc.T("ProcessingPleaseWait")';
                }
                overlay.classList.add('is-visible');
                overlay.setAttribute('aria-hidden', 'false');
            });

            // Safety net: if user navigates back via bfcache and the page is
            // restored from cache with the overlay still visible, hide it.
            window.addEventListener('pageshow', function (ev) {
                if (ev.persisted) {
                    overlay.classList.remove('is-visible');
                    overlay.setAttribute('aria-hidden', 'true');
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = '@Loc.T("InterpretAndSend")';
                    }
                }
            });
        })();
    </script>
}
