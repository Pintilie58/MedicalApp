@model MedicalApp.Models.DuplicateDetectedViewModel
@{
    ViewData["Title"] = Loc.T("DupPageTitle");
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-warning">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <span style="font-size:2rem;">&#9888;&#65039;</span>
                        <h3 class="mb-0 ms-3 text-warning fw-bold" data-testid="dup-heading">
                            @Loc.T("DupHeading")
                        </h3>
                    </div>

                    @* The "fileMatched" sentence uses two placeholders ({0} = file name,
                       {1} = profile name). Each placeholder is wrapped in <strong> via
                       Html.Raw so the bold rendering survives across all 5 languages
                       without duplicating the markup per locale. *@
                    <p class="lead" data-testid="dup-match-line">
                        @Html.Raw(string.Format(
                            Loc.T("DupFileMatchedFmt"),
                            $"<strong>{System.Net.WebUtility.HtmlEncode(Model.OriginalFileName)}</strong>",
                            $"<strong data-testid=\"dup-profile-name\">{System.Net.WebUtility.HtmlEncode(Model.ProfileName)}</strong>"))
                    </p>

                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <div>
                            <div class="small text-muted">@Loc.T("DupExistingLabel")</div>
                            <div class="fw-semibold" data-testid="dup-existing-date">
                                &#128197; @Model.ExistingCreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.ExistingFileName))
                            {
                                <div class="small text-muted">
                                    @Loc.T("DupOriginalFileLabel") @Model.ExistingFileName
                                </div>
                            }
                        </div>
                    </div>

                    <p class="text-muted">
                        @Loc.T("DupWhatToDo")
                    </p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100 d-flex flex-column">
                                <h5 class="text-primary fw-bold">
                                    &#11015;&#65039; @Loc.T("DupOpenExistingTitle")
                                </h5>
                                <p class="small text-muted flex-grow-1">
                                    @Loc.T("DupOpenExistingDesc")
                                    <strong class="text-success">@Loc.T("DupBadgeFree")</strong>
                                    @Loc.T("DupNoCreditNote")
                                </p>
                                <a asp-controller="Profiles" asp-action="DownloadReport"
                                   asp-route-id="@Model.ExistingHistoryId"
                                   class="btn btn-primary w-100"
                                   data-testid="btn-open-existing-report">
                                    @Loc.T("DupOpenExistingTitle")
                                </a>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100 d-flex flex-column">
                                <h5 class="text-warning fw-bold">
                                    &#128260; @Loc.T("DupReinterpretTitle")
                                </h5>
                                <p class="small text-muted flex-grow-1">
                                    @Loc.T("DupReinterpretDesc")
                                    <strong class="text-danger">@Loc.T("DupOneCreditWarning")</strong>
                                </p>
                                <form id="forceReinterpretForm" asp-action="Upload" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="force" value="true" />
                                    <input type="hidden" name="reuploadToken" value="@Model.ReuploadToken" />
                                    <input type="hidden" name="ProfileId" value="@Model.ProfileId" />
                                    <button type="submit" class="btn btn-outline-warning w-100"
                                            id="btnForceReinterpret"
                                            data-testid="btn-force-reinterpret">
                                        @Loc.T("DupBtnReinterpretFmt")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a asp-action="Upload" class="btn btn-link" data-testid="btn-dup-cancel">
                            &larr; @Loc.T("DupCancelLink")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Same processing overlay as on the Upload page so the user sees feedback
     when they click "Re-interpretează" (the call to Gemini takes 5-30 s).
     Uses the doctor mascot partial — kept identical to Upload.cshtml so the
     loading experience is consistent across both entry points. -->
<div id="processingOverlay" class="processing-overlay" aria-hidden="true" role="status" aria-live="polite">
    <div class="processing-box">
        <h3 class="processing-title">@Loc.T("PleaseWaitFewSeconds")</h3>
        @{
            var dupMascotVd = new ViewDataDictionary(ViewData)
            {
                ["Mode"] = "waiting",
                ["Size"] = "medium",
                ["StageId"] = "duplicateWaitMascot",
                ["TestId"] = "duplicate-wait-mascot"
            };
        }
        <partial name="_DoctorMascot" view-data="dupMascotVd" />
        <p class="processing-subtitle">@Loc.T("PleaseWaitDoNotClose")</p>
    </div>
</div>

<style>
    .processing-overlay {
        display: none; position: fixed; inset: 0; z-index: 2000;
        background: rgba(13, 71, 161, 0.85);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        align-items: center; justify-content: center;
        animation: fadeIn 0.25s ease-out;
    }
    .processing-overlay.is-visible { display: flex; }
    .processing-box {
        background: #ffffff; border-radius: 16px; padding: 40px 48px;
        text-align: center; max-width: 440px; width: calc(100% - 40px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }
    .processing-title { color: #0d47a1; font-weight: 700; margin: 0 0 12px 0; font-size: 1.5rem; }
    .processing-subtitle { color: #546e7a; margin: 0; font-size: 0.95rem; line-height: 1.5; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

@section Scripts {
    <script>
        // Localized label restored when the user uses browser-back / bfcache
        // (the form submit replaced the button text with "Processing..."). We
        // inject the localized "Re-interpret (1 credit)" via Loc.T so the
        // restoration matches the current UI language.
        (function () {
            var form = document.getElementById('forceReinterpretForm');
            var btn = document.getElementById('btnForceReinterpret');
            var overlay = document.getElementById('processingOverlay');
            var reinterpretLabel = '@Loc.T("DupBtnReinterpretFmt")';
            if (!form || !overlay) return;

            form.addEventListener('submit', function () {
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML = '@Loc.T("ProcessingPleaseWait")';
                }
                overlay.classList.add('is-visible');
                overlay.setAttribute('aria-hidden', 'false');
            });

            window.addEventListener('pageshow', function (ev) {
                if (ev.persisted) {
                    overlay.classList.remove('is-visible');
                    overlay.setAttribute('aria-hidden', 'true');
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = reinterpretLabel;
                    }
                }
            });
        })();
    </script>
}
