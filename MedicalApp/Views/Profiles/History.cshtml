@model MedicalApp.Models.ProfileHistoryViewModel
@{
    ViewData["Title"] = string.Format(Loc.T("HistoryPageTitleFmt"), Model.ProfileName);
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
                <h2 class="text-primary fw-bold mb-0" data-testid="history-heading">
                    &#128218; @string.Format(Loc.T("HistoryHeadingFmt"), Model.ProfileName)
                </h2>
                @if (!string.IsNullOrWhiteSpace(Model.Relationship))
                {
                    <span class="badge bg-secondary align-self-center">@Model.Relationship</span>
                }
                <span class="badge bg-info text-dark align-self-center" data-testid="history-total-count">
                    @Model.Items.Count @(Model.Items.Count == 1
                        ? Loc.T("HistoryInterpretationSingular")
                        : Loc.T("HistoryInterpretationPlural"))
                </span>
                <div class="ms-auto">
                    <a asp-action="Index" class="btn btn-outline-secondary" data-testid="btn-back-profiles">
                        &larr; @Loc.T("HistoryBackToProfiles")
                    </a>
                </div>
            </div>

            <p class="text-muted mb-3">
                @Loc.T("HistoryIntro")
            </p>

            @* Premium info banner — the "until {date}" / "{count}" placeholders are
               wrapped in <strong> at render time via Html.Raw + string.Format, so the
               translation string only carries the {0} marker (no HTML in Loc.cs). *@
            @if (Model.IsInFreePeriod)
            {
                <div class="alert alert-success py-2 small" data-testid="premium-free-period-banner">
                    &#127873;
                    @Html.Raw(string.Format(
                        System.Net.WebUtility.HtmlEncode(Loc.T("HistoryPremiumFreeFmt")),
                        $"<strong>{System.Net.WebUtility.HtmlEncode(Model.FreeUntil.ToLocalTime().ToString("dd MMM yyyy"))}</strong>"))
                </div>
            }
            else
            {
                <div class="alert alert-info py-2 small" data-testid="premium-paid-period-banner">
                    &#128176;
                    @{
                        var paidFmtKey = Model.FreeUsesLeftInBundle == 1
                            ? "HistoryPremiumPaidFmtSingular"
                            : "HistoryPremiumPaidFmtPlural";
                    }
                    @Html.Raw(string.Format(
                        System.Net.WebUtility.HtmlEncode(Loc.T(paidFmtKey)),
                        $"<strong>{Model.FreeUsesLeftInBundle}</strong>"))
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" data-testid="history-success-msg">@successMessage</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" data-testid="history-error-msg">@errorMessage</div>
            }

            @if (!Model.Items.Any())
            {
                <div class="alert alert-info" data-testid="history-empty-state">
                    @Loc.T("HistoryEmptyMsg")
                    <a asp-controller="Interpretation" asp-action="Upload" class="alert-link">
                        @Loc.T("HistoryEmptyLink")
                    </a>.
                </div>
            }
            else
            {
                @* Outer form is empty (just holds the submit button + hidden fields).
                   Checkboxes inside the table reference it via the `form` attribute,
                   so the table can keep its own per-row Delete forms without nested
                   <form> tags (which are invalid HTML). *@
                <form id="compareForm" asp-action="Compare" method="get">
                    <input type="hidden" name="profileId" value="@Model.ProfileId" />
                    @{
                        // Evolution charts need at least 2 data points per parameter,
                        // so the button stays disabled while the archive has only one
                        // interpretation. Same applies to the Compare button below,
                        // but Compare is already disabled by JS until 2..4 rows are
                        // ticked — we just guarantee it can never become enabled here.
                        var hasMultiple = Model.Items.Count >= 2;
                        var lockReason = hasMultiple ? null : Loc.T("HistoryEvolutionDisabled");
                    }
                    <div class="d-flex align-items-center mb-2 gap-2 flex-wrap">
                        <span class="small text-muted" data-testid="history-compare-hint">
                            @Loc.T("HistoryCompareHint")
                            <span id="compareSelCount" class="badge bg-secondary ms-2"
                                  data-testid="history-selected-count">0</span>
                        </span>
                        @* Disabled buttons swallow all mouse events, so the native `title`
                           tooltip would never appear on hover. We wrap them in a span that
                           is NOT disabled and carries the title itself — that span catches
                           the hover and shows the explanatory tooltip while the button
                           stays visually disabled. *@
                        <span class="ms-auto d-inline-block"
                              title="@lockReason"
                              tabindex="0"
                              data-testid="evolution-btn-wrap">
                            <button type="button" class="btn btn-outline-primary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#evolutionModal"
                                    data-testid="btn-open-evolution"
                                    disabled="@(!hasMultiple)"
                                    style="@(hasMultiple ? "" : "pointer-events:none;")">
                                &#128200; @Loc.T("HistoryBtnEvolution")
                            </button>
                        </span>
                        <span class="d-inline-block"
                              title="@lockReason"
                              tabindex="0"
                              data-testid="compare-btn-wrap">
                            <button type="submit" id="btnCompare" class="btn btn-primary btn-sm"
                                    disabled data-testid="btn-compare-selected"
                                    style="@(hasMultiple ? "" : "pointer-events:none;")">
                                &#128200; @Loc.T("HistoryBtnCompare")
                            </button>
                        </span>
                    </div>
                </form>

                @* ---- Evolution modal ----
                   Standalone form that POSTs (technically GETs) to /Profiles/Evolution
                   with the user-pasted LOINC codes. Separated from the Compare form so
                   we don't accidentally submit both. *@
                <div class="modal fade" id="evolutionModal" tabindex="-1"
                     aria-labelledby="evolutionModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <form asp-action="Evolution" method="get">
                                <input type="hidden" name="profileId" value="@Model.ProfileId" />
                                <div class="modal-header">
                                    <h5 class="modal-title" id="evolutionModalLabel">
                                        &#128200; @Loc.T("HistoryEvolutionModalTitle")
                                    </h5>
                                    <button type="button" class="btn-close"
                                            data-bs-dismiss="modal" aria-label="@Loc.T("CloseAria")"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="small text-muted">
                                        @Loc.T("HistoryEvolutionModalIntro")
                                    </p>
                                    <div class="mb-3">
                                        <label for="evolutionCodes" class="form-label fw-semibold">
                                            @Loc.T("HistoryEvolutionLabel")
                                        </label>
                                        <textarea id="evolutionCodes" name="codes" rows="3"
                                                  class="form-control" required
                                                  placeholder="@Loc.T("HistoryEvolutionPlaceholder")"
                                                  data-testid="evolution-codes-input"></textarea>
                                        <div class="form-text">
                                            @Loc.T("HistoryEvolutionHelp")
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary"
                                            data-bs-dismiss="modal">@Loc.T("ProfilesDeleteConfirmCancel")</button>
                                    <button type="submit" class="btn btn-primary"
                                            data-testid="btn-submit-evolution">
                                        @Loc.T("HistoryBtnGenerateChart")
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle" data-testid="history-table">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px;"></th>
                                <th>@Loc.T("HistoryThDate")</th>
                                <th>@Loc.T("HistoryThFile")</th>
                                <th>@Loc.T("HistoryThSampleDate")</th>
                                <th class="text-center">@Loc.T("HistoryThParams")</th>
                                <th class="text-center">@Loc.T("HistoryThAbnormal")</th>
                                <th class="text-end">@Loc.T("HistoryThActions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model.Items)
                            {
                                <tr data-testid="history-row-@h.Id">
                                    <td>
                                        @if (h.HasRawJson)
                                        {
                                            <input type="checkbox" class="form-check-input compare-check"
                                               form="compareForm"
                                               name="ids" value="@h.Id"
                                               data-testid="history-check-@h.Id" />
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@h.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                        <div class="small text-muted">@h.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        <span class="text-break">@(h.OriginalFileName ?? "-")</span>
                                        @if (!string.IsNullOrWhiteSpace(h.Language))
                                        {
                                            <span class="badge bg-light text-muted ms-1">@h.Language</span>
                                        }
                                    </td>
                                    <td class="text-muted">@(h.DateTaken ?? "-")</td>
                                    <td class="text-center">
                                        @if (h.KeyResultsCount.HasValue)
                                        {
                                            <span class="badge bg-primary">@h.KeyResultsCount</span>
                                        }
                                        else { <span class="text-muted">-</span> }
                                    </td>
                                    <td class="text-center">
                                        @if (h.AbnormalFindingsCount.HasValue && h.AbnormalFindingsCount.Value > 0)
                                        {
                                            <span class="badge bg-danger">@h.AbnormalFindingsCount</span>
                                        }
                                        else if (h.AbnormalFindingsCount.HasValue)
                                        {
                                            <span class="badge bg-success">0</span>
                                        }
                                        else { <span class="text-muted">-</span> }
                                    </td>
                                    <td class="text-end">
                                        @if (h.HasRawJson)
                                        {
                                            <a asp-action="DownloadReport" asp-route-id="@h.Id"
                                               class="btn btn-sm btn-primary"
                                               data-testid="btn-download-report-@h.Id">
                                                &#11015; @Loc.T("HistoryBtnDownloadPdf")
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="small text-muted"
                                                  title="@Loc.T("HistoryUnavailableTooltip")">
                                                @Loc.T("HistoryUnavailable")
                                            </span>
                                        }
                                        <form asp-action="DeleteHistory" method="post"
                                              class="d-inline ms-1 js-delete-history-form"
                                              data-history-date="@h.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")"
                                              data-history-file="@(h.OriginalFileName ?? "")">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@h.Id" />
                                            <input type="hidden" name="profileId" value="@Model.ProfileId" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="@Loc.T("HistoryDeleteTooltip")"
                                                    data-testid="btn-delete-history-@h.Id">
                                                &#128465;
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete-history confirmation modal (custom, no "localhost says" header). -->
<div class="modal fade" id="deleteHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    &#9888;&#65039; @Loc.T("ProfilesDeleteConfirmTitle")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@Loc.T("CloseAria")"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">
                    @Loc.T("HistoryDeleteConfirmMsg")
                </p>
                <ul class="small text-muted mb-2">
                    <li>@Loc.T("HistoryDeleteFieldDate") <strong id="deleteHistoryDate">-</strong></li>
                    <li>@Loc.T("HistoryDeleteFieldFile") <strong id="deleteHistoryFile">-</strong></li>
                </ul>
                <p class="small text-muted mb-0">
                    @Loc.T("HistoryDeleteConfirmNote")
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                        data-testid="btn-cancel-delete-history">@Loc.T("ProfilesDeleteConfirmCancel")</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteHistoryBtn"
                        data-testid="btn-confirm-delete-history">
                    &#128465; @Loc.T("ProfilesDeleteConfirmYes")
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var btn = document.getElementById('btnCompare');
            var form = document.getElementById('compareForm');
            var counter = document.getElementById('compareSelCount');
            if (!btn || !form) return;

            var MIN = 2, MAX = 4;

            function selected() {
                return Array.prototype.slice.call(
                    document.querySelectorAll('.compare-check:checked'));
            }

            function refresh() {
                var sel = selected();
                // Cap at MAX: uncheck the oldest selection when the next one is ticked.
                while (sel.length > MAX) {
                    sel[0].checked = false;
                    sel = selected();
                }
                btn.disabled = sel.length < MIN || sel.length > MAX;
                if (counter) {
                    counter.textContent = sel.length + '/' + MAX;
                    counter.className = 'badge ms-2 ' +
                        (sel.length >= MIN && sel.length <= MAX ? 'bg-primary' : 'bg-secondary');
                }
            }

            document.querySelectorAll('.compare-check').forEach(function (cb) {
                cb.addEventListener('change', refresh);
            });
            refresh();

            // The route accepts ids[] (param name: "ids"). The checkboxes already
            // have name="ids", so default form submit yields ?ids=12&ids=15&...
            // We just keep the unchecked ones from being sent (browser handles that).
            form.addEventListener('submit', function (e) {
                var sel = selected();
                if (sel.length < MIN || sel.length > MAX) { e.preventDefault(); return false; }
            });
        })();
    </script>

    <script>
        // Custom delete-history confirm modal (no "localhost says" prefix).
        (function () {
            var modalEl = document.getElementById('deleteHistoryModal');
            var dateEl = document.getElementById('deleteHistoryDate');
            var fileEl = document.getElementById('deleteHistoryFile');
            var confirmBtn = document.getElementById('confirmDeleteHistoryBtn');
            if (!modalEl || !confirmBtn) return;
            var modal = new bootstrap.Modal(modalEl);
            var pendingForm = null;

            document.querySelectorAll('.js-delete-history-form').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    pendingForm = form;
                    if (dateEl) dateEl.textContent = form.getAttribute('data-history-date') || '-';
                    if (fileEl) fileEl.textContent = form.getAttribute('data-history-file') || '-';
                    modal.show();
                });
            });

            confirmBtn.addEventListener('click', function () {
                if (pendingForm) {
                    confirmBtn.disabled = true;
                    pendingForm.submit();
                }
            });

            modalEl.addEventListener('hidden.bs.modal', function () {
                pendingForm = null;
                confirmBtn.disabled = false;
            });
        })();
    </script>
}
