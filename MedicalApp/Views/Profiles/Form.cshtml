@model MedicalApp.Models.ProfileFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? Loc.T("ProfileFormTitleEdit") : Loc.T("ProfileFormTitleNew");
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h3 class="text-primary fw-bold mb-4">
                @if (isEdit)
                {
                    @Loc.T("ProfileFormHeadingEdit")
                }
                else
                {
                    <text>&#43; @Loc.T("ProfileFormHeadingNew")</text>
                }
            </h3>

            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                @if (isEdit) { <input type="hidden" asp-for="Id" /> }
                <input type="hidden" asp-for="IsDefault" />

                <div asp-validation-summary="All" class="text-danger small mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">@Loc.T("ProfileLabelName")</label>
                    <input asp-for="Name" class="form-control" placeholder="@Loc.T("ProfilePlaceholderName")"
                           autocomplete="off" data-testid="profile-name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                    @if (Model.IsDefault)
                    {
                        <div class="form-text">
                            @Loc.T("ProfileFormDefaultNote")
                        </div>
                    }
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Relationship" class="form-label">@Loc.T("ProfileLabelRelationship")</label>
                        <select asp-for="Relationship" class="form-select" data-testid="profile-relationship">
                            <option value="">@Loc.T("ProfileSelectOptional")</option>
                            <option value="self">@Loc.T("ProfileRelSelf")</option>
                            <option value="mother">@Loc.T("ProfileRelMother")</option>
                            <option value="father">@Loc.T("ProfileRelFather")</option>
                            <option value="child">@Loc.T("ProfileRelChild")</option>
                            <option value="sibling">@Loc.T("ProfileRelSibling")</option>
                            <option value="partner">@Loc.T("ProfileRelPartner")</option>
                            <option value="friend">@Loc.T("ProfileRelFriend")</option>
                            <option value="other">@Loc.T("ProfileRelOther")</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">@Loc.T("ProfileLabelGender")</label>
                        <select asp-for="Gender" class="form-select" data-testid="profile-gender">
                            <option value="">@Loc.T("ProfileSelectOptional")</option>
                            <option value="M">@Loc.T("ProfileGenderMale")</option>
                            <option value="F">@Loc.T("ProfileGenderFemale")</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="BirthYear" class="form-label">@Loc.T("ProfileLabelBirthYear")</label>
                    <input asp-for="BirthYear" type="number" min="1900" max="2100" class="form-control"
                           placeholder="1965" data-testid="profile-birthyear" />
                    <span asp-validation-for="BirthYear" class="text-danger small"></span>
                    <div class="form-text">
                        @Loc.T("ProfileBirthYearHelp")
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="CardiovascularRisk" class="form-label">
                        &#129000; @Loc.T("ProfileLabelCvRisk")
                    </label>
                    <select asp-for="CardiovascularRisk" class="form-select"
                            data-testid="profile-cv-risk">
                        <option value="">@Loc.T("ProfileCvRiskUnknown")</option>
                        <option value="low_moderate">@Loc.T("ProfileCvRiskLowMod")</option>
                        <option value="high">@Loc.T("ProfileCvRiskHigh")</option>
                        <option value="very_high">@Loc.T("ProfileCvRiskVeryHigh")</option>
                    </select>
                    <div class="form-text">
                        @Loc.T("ProfileCvRiskHelp")
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label">@Loc.T("ProfileLabelNotes")</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="@Loc.T("ProfilePlaceholderNotes")"
                              data-testid="profile-notes"></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" data-testid="profile-submit">
                        @(isEdit ? Loc.T("ProfileBtnSave") : Loc.T("ProfileBtnCreate"))
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@Loc.T("ProfileBtnCancel")</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
}
