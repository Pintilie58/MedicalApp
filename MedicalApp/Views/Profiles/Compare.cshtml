@model MedicalApp.Models.CompareInterpretationsViewModel
@{
    ViewData["Title"] = $"Comparație - {Model.ProfileName}";

    string CellClass(string d) => d switch
    {
        "first"     => "table-light",
        "risen"     => "table-danger",
        "fallen"    => "table-info",
        "unchanged" => "",
        "absent"    => "table-warning text-muted fst-italic",
        _ => ""
    };
    string CellIcon(string d) => d switch
    {
        "risen"     => "<span style=\"color:#dc3545;font-weight:600;\">&#8599;</span>",   // ↗ roșu
        "fallen"    => "<span style=\"color:#0d6efd;font-weight:600;\">&#8600;</span>",   // ↘ albastru
        "unchanged" => "",
        "first"     => "",
        "absent"    => "<span class=\"text-muted\">&mdash;</span>",
        _ => ""
    };
    string StatusBadge(string? status) => status?.ToLowerInvariant() switch
    {
        "high"       => "<span class=\"badge bg-danger\">&#8593;</span>",
        "low"        => "<span class=\"badge bg-primary\">&#8595;</span>",
        "borderline" => "<span class=\"badge bg-warning text-dark\">&#8776;</span>",
        "normal"     => "<span class=\"badge bg-success\">&#10003;</span>",
        _ => ""
    };
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xxl-11">
            <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
                <h2 class="text-primary fw-bold mb-0" data-testid="compare-heading">
                    &#128200; Comparație: @Model.ProfileName
                </h2>
                <span class="badge bg-secondary align-self-center" data-testid="compare-column-count">
                    @Model.Columns.Count interpretări
                </span>
                <div class="ms-auto">
                    <a asp-action="History" asp-route-id="@Model.ProfileId"
                       class="btn btn-outline-secondary" data-testid="btn-back-history">
                        &larr; Înapoi la arhivă
                    </a>
                </div>
            </div>

            @if (Model.CreditConsumed)
            {
                <div class="alert alert-warning" data-testid="compare-credit-consumed-msg">
                    &#128181; A fost consumat 1 credit pentru această comparație
                    (pachetul de 3 utilizări gratuite a fost epuizat).
                </div>
            }

            <p class="text-muted small mb-3">
                Coloanele sunt ordonate cronologic, <strong>de la stânga (mai vechi)</strong>
                la <strong>dreapta (mai recent)</strong>, după <strong>data recoltării</strong>
                (sau, dacă lipsește, după data interpretării).
            </p>

            @* Column headers as cards *@
            <div class="row g-2 mb-3">
                @{
                    var colorByIdx = new[] { "border-primary", "border-info", "border-warning", "border-success" };
                }
                @for (int i = 0; i < Model.Columns.Count; i++)
                {
                    var col = Model.Columns[i];
                    var border = colorByIdx[i % colorByIdx.Length];
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card @border h-100" data-testid="compare-col-card-@i">
                            <div class="card-body py-2">
                                <div class="small text-muted">Interpretarea @(i + 1)</div>
                                <h6 class="fw-bold mb-1" data-testid="compare-col-sampled-@i">
                                    Recoltare:
                                    <span class="text-dark">
                                        @(string.IsNullOrWhiteSpace(col.DateTaken)
                                            ? col.EffectiveDate.ToLocalTime().ToString("dd MMM yyyy")
                                            : col.DateTaken)
                                    </span>
                                </h6>
                                <div class="small text-muted">
                                    Interpretat: @col.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                                </div>
                                <div class="small text-muted">
                                    @col.KeyResultsCount parametri · @col.AbnormalFindingsCount anormalități
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3" data-testid="compare-summary-badges">
                <span class="badge bg-danger">&#8599; Crescute: @Model.RisenCount</span>
                <span class="badge bg-info text-dark">&#8600; Scăzute: @Model.FallenCount</span>
                <span class="badge bg-success">= Neschimbate: @Model.UnchangedCount</span>
                @if (Model.PartialCount > 0)
                {
                    <span class="badge bg-warning text-dark" data-testid="compare-partial-badge">
                        &#9888; Doar parțial: @Model.PartialCount
                    </span>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle" data-testid="compare-table">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:180px;">Parametru</th>
                            @for (int i = 0; i < Model.Columns.Count; i++)
                            {
                                var col = Model.Columns[i];
                                <th class="text-center" style="min-width:140px;">
                                    @(string.IsNullOrWhiteSpace(col.DateTaken)
                                        ? col.EffectiveDate.ToLocalTime().ToString("dd MMM yyyy")
                                        : col.DateTaken)
                                </th>
                            }
                            <th class="text-muted small">Referință</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            @if (row.IsFirstInClass)
                            {
                                <tr class="table-secondary" data-testid="compare-class-header-@row.LoincClass">
                                    <td colspan="@(Model.Columns.Count + 2)"
                                        class="fw-bold text-uppercase small text-dark py-2"
                                        style="letter-spacing:.04em; background:#eef3ff;">
                                        &#129516; @row.ClassDisplayLabel
                                        @if (!string.IsNullOrWhiteSpace(row.LoincClass))
                                        {
                                            <span class="badge bg-light text-secondary border ms-2 small fw-normal"
                                                  title="Cod LOINC CLASS oficial">
                                                @row.LoincClass
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                            <tr data-testid="compare-row-@row.Parameter.Replace(" ", "-")">
                                <td class="fw-semibold" data-testid="compare-row-label">
                                    @row.Parameter
                                    @if (!string.IsNullOrWhiteSpace(row.Unit))
                                    { <span class="small text-muted">(@row.Unit)</span> }
                                    @if (!string.IsNullOrWhiteSpace(row.LoincCode))
                                    {
                                        <span class="badge bg-light text-secondary border ms-1 small"
                                              title="@row.LoincLongName"
                                              data-testid="compare-row-loinc-@row.LoincCode">
                                            LOINC @row.LoincCode
                                        </span>
                                        <span class="badge ms-1 small @MedicalApp.Services.LoincSourceBadge.GetBadgeClass(row.LoincSource)"
                                              title="@MedicalApp.Services.LoincSourceBadge.GetTooltip(row.LoincSource)"
                                              data-testid="compare-row-source-@row.LoincSource">
                                            @MedicalApp.Services.LoincSourceBadge.GetGlyph(row.LoincSource)
                                            @MedicalApp.Services.LoincSourceBadge.GetLabel(row.LoincSource)
                                        </span>
                                    }
                                </td>
                                @foreach (var cell in row.Cells)
                                {
                                    <td class="text-center @CellClass(cell.CellDirection)">
                                        @if (cell.CellDirection == "absent")
                                        {
                                            <span>—</span>
                                        }
                                        else
                                        {
                                            <span class="d-inline-flex align-items-center gap-1">
                                                <span>@(cell.Value ?? "-")</span>
                                                @Html.Raw(StatusBadge(cell.Status))
                                                @Html.Raw(CellIcon(cell.CellDirection))
                                            </span>
                                        }
                                    </td>
                                }
                                <td class="small text-muted">@(row.ReferenceRange ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="small text-muted mt-3">
                Rândurile sunt grupate pe <strong>clase de analize</strong>
                (Hematologie, Coagulare, Biochimie serică, Endocrinologie, Serologie,
                Biochimie urinară etc.) folosind <strong>câmpul oficial LOINC CLASS</strong>,
                exact ca în ordinea standard a unui buletin de analize.
                În interiorul fiecărei clase, rândurile sunt aliniate după
                <strong>codul LOINC</strong> când acesta este disponibil — același test
                apare pe același rând chiar dacă laboratoarele l-au scris diferit
                (ex. „VSH", „ESR" și „Vitesse de sédimentation" apar pe un singur rând).
                <br />
                Prima coloană (cea cu fundal gri) este referința.
                &#8599; roșu = valoare crescută față de prima coloană &nbsp;·&nbsp;
                &#8600; albastru = scăzută &nbsp;·&nbsp;
                = neschimbat &nbsp;·&nbsp;
                galben „—" = parametru lipsă în interpretarea respectivă.
                <br />
                <span class="badge bg-success-subtle text-success border border-success-subtle small">✓ verificat</span>
                — codul LOINC este garantat corect (folosit de sistemele medicale).
                &nbsp;
                <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle small">~ auto</span>
                — codul a fost sugerat automat de matcher (verifică pe loinc.org dacă e analiză rară).
            </p>
        </div>
    </div>
</div>
