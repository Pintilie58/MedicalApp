@model MedicalApp.Models.CompareInterpretationsViewModel
@{
    ViewData["Title"] = string.Format(MedicalApp.Services.Loc.T("CompareViewTabTitle"), Model.ProfileName);

    string CellClass(string d) => d switch
    {
        "first"     => "table-light",
        "risen"     => "table-danger",
        "fallen"    => "table-info",
        "unchanged" => "",
        "absent"    => "table-warning text-muted fst-italic",
        _ => ""
    };
    string CellIcon(string d) => d switch
    {
        "risen"     => "<span style=\"color:#dc3545;font-weight:600;\">&#8599;</span>",   // ↗ roșu
        "fallen"    => "<span style=\"color:#0d6efd;font-weight:600;\">&#8600;</span>",   // ↘ albastru
        "unchanged" => "",
        "first"     => "",
        "absent"    => "<span class=\"text-muted\">&mdash;</span>",
        _ => ""
    };
    string StatusBadge(string? status) => status?.ToLowerInvariant() switch
    {
        "high"       => "<span class=\"badge bg-danger\">&#8593;</span>",
        "low"        => "<span class=\"badge bg-primary\">&#8595;</span>",
        "borderline" => "<span class=\"badge bg-warning text-dark\">&#8776;</span>",
        "normal"     => "<span class=\"badge bg-success\">&#10003;</span>",
        _ => ""
    };
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xxl-11">
            <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
                <h2 class="text-primary fw-bold mb-0" data-testid="compare-heading">
                    &#128200; @Loc.T("CompareViewTitle") @Model.ProfileName
                </h2>
                <span class="badge bg-secondary align-self-center" data-testid="compare-column-count">
                    @string.Format(Loc.T("ProfileCompareInterpretationsCount"), Model.Columns.Count)
                </span>
                <div class="ms-auto d-flex gap-2 flex-wrap">
                    @if (Model.Columns.Count >= CompareInterpretationsViewModel.MinSelections)
                    {
                        <button type="button" id="btnCompareExportDownload"
                                class="btn btn-outline-primary"
                                data-testid="btn-compare-export-download">
                            &#128229; @Loc.T("CompareViewDownloadPdf")
                        </button>
                        <button type="button" id="btnCompareExportEmail"
                                class="btn btn-outline-success"
                                data-testid="btn-compare-export-email">
                            &#9993; @Loc.T("CompareViewSendEmail")
                        </button>
                    }
                    <a asp-action="History" asp-route-id="@Model.ProfileId"
                       class="btn btn-outline-secondary" data-testid="btn-back-history">
                        &larr; @Loc.T("CompareViewBackToArchive")
                    </a>
                </div>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" data-testid="compare-success">
                    @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" data-testid="compare-error">
                    @TempData["ErrorMessage"]
                </div>
            }

            @if (Model.CreditConsumed)
            {
                <div class="alert alert-warning" data-testid="compare-credit-consumed-msg">
                    &#128181; @Loc.T("CompareViewCreditConsumed")
                </div>
            }

            <p class="text-muted small mb-3">
                @Loc.T("ProfileCompareColumnOrderHint")
            </p>

            @* Column headers as cards *@
            <div class="row g-2 mb-3">
                @{
                    var colorByIdx = new[] { "border-primary", "border-info", "border-warning", "border-success" };
                }
                @for (int i = 0; i < Model.Columns.Count; i++)
                {
                    var col = Model.Columns[i];
                    var border = colorByIdx[i % colorByIdx.Length];
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="card @border h-100" data-testid="compare-col-card-@i">
                            <div class="card-body py-2">
                                <div class="small text-muted">@string.Format(Loc.T("ProfileCompareInterpretationN"), i + 1)</div>
                                @if (!string.IsNullOrWhiteSpace(col.PatientName))
                                {
                                    <div class="fw-semibold text-dark mb-1"
                                         data-testid="compare-col-patient-@i"
                                         title="@Loc.T("CompareViewPatientTooltip")">
                                        <span class="text-muted small">@Loc.T("ProfileComparePatientLabel")</span> @col.PatientName
                                    </div>
                                }
                                <h6 class="fw-bold mb-1" data-testid="compare-col-sampled-@i">
                                    @Loc.T("ProfileCompareSamplingLabel")
                                    <span class="text-dark">
                                        @col.EffectiveDate.ToLocalTime().ToString("yyyy-MM-dd")
                                    </span>
                                </h6>
                                <div class="small text-muted">
                                    @Loc.T("ProfileCompareInterpretedLabel") @col.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                                </div>
                                <div class="small text-muted">
                                    @string.Format(Loc.T("ProfileCompareParamsAbnormalFormat"), col.KeyResultsCount, col.AbnormalFindingsCount)
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mb-3" data-testid="compare-summary-badges">
                <span class="badge bg-danger">@string.Format(Loc.T("ProfileCompareBadgeRisen"), Model.RisenCount)</span>
                <span class="badge bg-info text-dark">@string.Format(Loc.T("ProfileCompareBadgeFallen"), Model.FallenCount)</span>
                <span class="badge bg-success">@string.Format(Loc.T("ProfileCompareBadgeUnchanged"), Model.UnchangedCount)</span>
                @if (Model.PartialCount > 0)
                {
                    <span class="badge bg-warning text-dark" data-testid="compare-partial-badge">
                        @string.Format(Loc.T("ProfileCompareBadgePartial"), Model.PartialCount)
                    </span>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle" data-testid="compare-table">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:180px;">@Loc.T("ProfileCompareHeaderParameter")</th>
                            @for (int i = 0; i < Model.Columns.Count; i++)
                            {
                                var col = Model.Columns[i];
                                <th class="text-center" style="min-width:140px;">
                                    @col.EffectiveDate.ToLocalTime().ToString("yyyy-MM-dd")
                                </th>
                            }
                            <th class="text-muted small">@Loc.T("ProfileCompareHeaderReference")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            @if (row.IsFirstInClass)
                            {
                                <tr class="table-secondary" data-testid="compare-class-header-@row.LoincClass">
                                    <td colspan="@(Model.Columns.Count + 2)"
                                        class="fw-bold text-uppercase small text-dark py-2"
                                        style="letter-spacing:.04em; background:#eef3ff;">
                                        &#129516; @row.ClassDisplayLabel
                                        @if (!string.IsNullOrWhiteSpace(row.LoincClass))
                                        {
                                            <span class="badge bg-light text-secondary border ms-2 small fw-normal"
                                                  title="@Loc.T("CompareViewLoincClassTooltip")">
                                                @row.LoincClass
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                            <tr data-testid="compare-row-@row.Parameter.Replace(" ", "-")">
                                <td class="fw-semibold" data-testid="compare-row-label">
                                    @row.Parameter
                                    @if (!string.IsNullOrWhiteSpace(row.Unit))
                                    { <span class="small text-muted">(@row.Unit)</span> }
                                    @if (row.HasLoincDrift)
                                    {
                                        <span class="ms-1"
                                              style="color:#fd7e14;cursor:help;font-weight:700;"
                                              title="@string.Format(Loc.T("CompareViewDriftWarningTooltip"), row.Parameter, row.LoincCode, string.Join(", ", row.DriftLoincCodes))"
                                              data-testid="compare-row-drift-warning">&#9888;</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(row.LoincCode))
                                    {
                                        <span class="badge bg-light text-secondary border ms-1 small"
                                              title="@row.LoincLongName"
                                              data-testid="compare-row-loinc-@row.LoincCode">
                                            LOINC @row.LoincCode
                                        </span>
                                        <span class="d-inline-block rounded-circle ms-1"
                                              style="width:9px;height:9px;background:@MedicalApp.Services.LoincSourceBadge.GetDotColor(row.LoincSource);vertical-align:middle;"
                                              title="@MedicalApp.Services.LoincSourceBadge.GetTooltip(row.LoincSource)"
                                              data-testid="compare-row-source-@row.LoincSource">
                                        </span>
                                        @if (!MedicalApp.Services.LoincSourceBadge.IsVerified(row.LoincSource) && row.LoincScore.HasValue)
                                        {
                                            <span class="small text-muted ms-1"
                                                  data-testid="compare-row-score">@((int)Math.Round(row.LoincScore.Value * 100))%</span>
                                        }
                                    }
                                </td>
                                @foreach (var cell in row.Cells)
                                {
                                    <td class="text-center @CellClass(cell.CellDirection)">
                                        @if (cell.CellDirection == "absent")
                                        {
                                            <span>—</span>
                                        }
                                        else
                                        {
                                            <span class="d-inline-flex align-items-center gap-1">
                                                <span>@(cell.Value ?? "-")</span>
                                                @Html.Raw(StatusBadge(cell.Status))
                                                @Html.Raw(CellIcon(cell.CellDirection))
                                            </span>
                                        }
                                    </td>
                                }
                                <td class="small text-muted">@(row.ReferenceRange ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="small text-muted mt-3">
                @Loc.T("CompareViewLegendGrouping")
                <br />
                @Loc.T("CompareViewLegendColors")
                <br />
                <span class="d-inline-block rounded-circle" style="width:9px;height:9px;background:#198754;vertical-align:middle;"></span>
                @Loc.T("LoincSourceLegendVerified")
                &nbsp;·&nbsp;
                <span class="d-inline-block rounded-circle" style="width:9px;height:9px;background:#0d6efd;vertical-align:middle;"></span>
                @Loc.T("LoincSourceLegendAuto")
                &nbsp;·&nbsp;
                <span style="color:#fd7e14;font-weight:700;">&#9888;</span>
                @Loc.T("CompareViewLegendDrift")
            </p>
        </div>
    </div>
</div>

@if (Model.Columns.Count >= CompareInterpretationsViewModel.MinSelections)
{
    @* Hidden form used to POST to CompareExport. Anti-forgery token is
       auto-injected by the form tag helper. Mirrors Evolution's pattern. *@
    <form id="compareExportForm" asp-action="CompareExport" method="post" style="display:none;">
        <input type="hidden" name="ProfileId" value="@Model.ProfileId" />
        @foreach (var c in Model.Columns)
        {
            <input type="hidden" name="Ids" value="@c.HistoryId" />
        }
        <input type="hidden" name="Mode" id="compareExportMode" value="download" />
    </form>

    <script>
        (function () {
            var form    = document.getElementById('compareExportForm');
            var modeEl  = document.getElementById('compareExportMode');
            var btnDl   = document.getElementById('btnCompareExportDownload');
            var btnMail = document.getElementById('btnCompareExportEmail');

            function submitAs(mode) {
                if (!form || !modeEl) return;
                modeEl.value = mode;
                form.submit();
            }
            if (btnDl)   btnDl.addEventListener('click',   function () { submitAs('download'); });
            if (btnMail) btnMail.addEventListener('click', function () { submitAs('email'); });
        })();
    </script>
}
