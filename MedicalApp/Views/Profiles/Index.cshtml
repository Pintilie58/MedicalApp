@model MedicalApp.Models.ProfilesIndexViewModel
@*
    /Profiles - list of the current user's health profiles (Eu, Mama, Tata, …).
    Each card shows quick stats and links to the archive (History) for that profile.
*@
@{
    ViewData["Title"] = "Profile";
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center mb-4 flex-wrap gap-2">
                <h2 class="text-primary fw-bold mb-0">&#128106; Profilele mele</h2>
                <span class="badge bg-secondary align-self-center" data-testid="profiles-total-count">
                    @Model.Profiles.Count total
                </span>
                <div class="ms-auto d-flex gap-2">
                    <a asp-controller="Account" asp-action="Dashboard"
                       class="btn btn-outline-secondary" data-testid="btn-back-dashboard">
                        &larr; Dashboard
                    </a>
                    <a asp-action="Create" class="btn btn-primary" data-testid="btn-create-profile">
                        &#43; Adaugă profil nou
                    </a>
                </div>
            </div>

            <p class="text-muted mb-4">
                Profilele îți permit să interpretezi analize pentru tine și pentru cei apropiați
                (mama, tata, copii, prieteni) folosind aceleași credite. Fiecare profil are
                istoric separat și permite urmărirea evoluției în timp.
            </p>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" data-testid="profile-success-msg">@successMessage</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" data-testid="profile-error-msg">@errorMessage</div>
            }

            @* Search bar - shows only when there are at least 4 profiles, to keep the
               UI clean for small lists. Filters client-side (instant, no server calls). *@
            @if (Model.Profiles.Count >= 4)
            {
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white">&#128269;</span>
                        <input type="search" id="profileSearch" class="form-control"
                               placeholder="Caută după nume, relație sau note..."
                               autocomplete="off" data-testid="profile-search-input" />
                        <button type="button" class="btn btn-outline-secondary" id="profileSearchClear"
                                title="Șterge filtrul" data-testid="profile-search-clear">
                            &times;
                        </button>
                    </div>
                    <div class="small text-muted mt-2" id="profileSearchInfo"
                         data-testid="profile-search-info"></div>
                </div>
            }

            @if (!Model.Profiles.Any())
            {
                <div class="alert alert-info">
                    Nu ai niciun profil. Cum fiecare cont are automat un profil &quot;Eu&quot; la creare, 
                    dacă vezi acest mesaj te rugăm să raportezi la admin.
                </div>
            }
            else
            {
                <div class="row g-3" data-testid="profiles-grid" id="profilesGrid">
                    @foreach (var p in Model.Profiles)
                    {
                        var badgeClass = p.IsDefault ? "bg-primary" : "bg-secondary";
                        var badgeLabel = p.IsDefault ? "Implicit" : (p.Relationship ?? "Profil");

                        <div class="col-md-6 col-lg-4 profile-card-wrapper"
                             data-name="@p.Name.ToLower()"
                             data-relationship="@(p.Relationship ?? "")"
                             data-notes="@((p.Notes ?? "").ToLower())">
                            <div class="card h-100 shadow-sm" data-testid="profile-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-start mb-2">
                                        <h5 class="card-title fw-bold mb-0">
                                            @p.Name
                                        </h5>
                                        <span class="badge @badgeClass ms-auto">@badgeLabel</span>
                                    </div>

                                    <dl class="row small text-muted mb-3 mt-3">
                                        @if (!string.IsNullOrWhiteSpace(p.Gender))
                                        {
                                            <dt class="col-6">Sex</dt><dd class="col-6">@p.Gender</dd>
                                        }
                                        @if (p.BirthYear.HasValue)
                                        {
                                            <dt class="col-6">An naștere</dt><dd class="col-6">@p.BirthYear</dd>
                                        }
                                        <dt class="col-6 text-nowrap">Interpretări</dt>
                                        <dd class="col-6 fw-bold text-dark">@p.InterpretationsCount</dd>
                                    </dl>

                                    @if (!string.IsNullOrWhiteSpace(p.Notes))
                                    {
                                        <div class="small bg-light border rounded p-2 mb-3" style="max-height:72px;overflow:hidden;">
                                            @p.Notes
                                        </div>
                                    }
                                </div>
                                <div class="card-footer bg-white border-0 pb-3">
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-action="History" asp-route-id="@p.Id"
                                           class="btn btn-sm btn-outline-info flex-grow-1"
                                           data-testid="btn-history-profile-@p.Id"
                                           title="Vezi arhiva interpretărilor pentru acest profil">
                                            &#128218; Arhivă (@p.InterpretationsCount)
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@p.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           data-testid="btn-edit-profile-@p.Id">
                                            &#9998; Editează
                                        </a>
                                        @if (!p.IsDefault)
                                        {
                                            <form asp-action="Delete" method="post"
                                                  class="m-0 js-delete-profile-form"
                                                  data-profile-name="@p.Name">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        data-testid="btn-delete-profile-@p.Id">
                                                    &#128465; Șterge
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mt-4">
            </div>
        </div>
    </div>
</div>

<!-- Delete confirmation modal (replaces native confirm() to avoid the
     "localhost:5001 says" header that browsers prepend to default dialogs). -->
<div class="modal fade" id="deleteProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    &#9888;&#65039; Confirmă ștergerea
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">
                    Ești sigur că vrei să ștergi profilul <strong id="deleteProfileName">-</strong>?
                </p>
                <p class="small text-muted mb-0">
                    Toate interpretările asociate acestui profil rămân în baza de date,
                    dar profilul în sine va dispărea. Această acțiune nu poate fi anulată.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                        data-testid="btn-cancel-delete-profile">
                    Anulează
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteProfileBtn"
                        data-testid="btn-confirm-delete-profile">
                    &#128465; Da, șterge
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Client-side live filter for the profiles grid.
        (function () {
            var input = document.getElementById('profileSearch');
            if (!input) return; // hidden when fewer than 4 profiles
            var clearBtn = document.getElementById('profileSearchClear');
            var info = document.getElementById('profileSearchInfo');
            var cards = document.querySelectorAll('.profile-card-wrapper');
            var total = cards.length;

            function normalize(s) {
                // lowercase + strip Romanian/French diacritics for forgiving search
                return (s || '').toString().toLowerCase()
                    .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            }

            function applyFilter() {
                var q = normalize(input.value.trim());
                var visible = 0;
                cards.forEach(function (card) {
                    var hay = normalize(
                        (card.getAttribute('data-name') || '') + ' ' +
                        (card.getAttribute('data-relationship') || '') + ' ' +
                        (card.getAttribute('data-notes') || '')
                    );
                    var show = q === '' || hay.indexOf(q) !== -1;
                    card.style.display = show ? '' : 'none';
                    if (show) visible++;
                });
                if (info) {
                    info.textContent = q === ''
                        ? ''
                        : (visible + ' din ' + total + ' profile se potrivesc cu „' + input.value + '”');
                }
            }

            input.addEventListener('input', applyFilter);
            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    input.value = '';
                    applyFilter();
                    input.focus();
                });
            }
        })();
    </script>

    <script>
        // Custom delete-confirmation flow (replaces window.confirm() to remove
        // the "localhost:5001 says" header).
        (function () {
            var modalEl = document.getElementById('deleteProfileModal');
            var nameEl = document.getElementById('deleteProfileName');
            var confirmBtn = document.getElementById('confirmDeleteProfileBtn');
            if (!modalEl || !confirmBtn) return;
            var modal = new bootstrap.Modal(modalEl);
            var pendingForm = null;

            document.querySelectorAll('.js-delete-profile-form').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    pendingForm = form;
                    if (nameEl) nameEl.textContent = form.getAttribute('data-profile-name') || '-';
                    modal.show();
                });
            });

            confirmBtn.addEventListener('click', function () {
                if (pendingForm) {
                    confirmBtn.disabled = true;
                    pendingForm.submit();
                }
            });

            modalEl.addEventListener('hidden.bs.modal', function () {
                pendingForm = null;
                confirmBtn.disabled = false;
            });
        })();
    </script>
}
