@model List<MedicalApp.Models.UserListItem>
@{
    ViewData["Title"] = "Admin - Users";
    var query = ViewBag.Query as string ?? "";
    var typeFilter = ViewBag.Type as string ?? "all";
    var page = (int)ViewBag.Page;
    var total = (int)ViewBag.Total;
    var totalPages = (int)ViewBag.TotalPages;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <h2 class="text-primary fw-bold mb-0">
            <i class="bi bi-people"></i> Users (@total)
        </h2>
        <div class="ms-auto">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Back to dashboard</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form method="get" class="mb-3">
        <div class="d-flex flex-wrap gap-3 align-items-end">
            <div class="input-group" style="max-width:500px;">
                <input type="text" name="q" value="@query" class="form-control"
                       placeholder="Search by email..." data-testid="users-search-input" />
                <input type="hidden" name="type" value="@typeFilter" />
                <button class="btn btn-primary" data-testid="users-search-submit">Search</button>
                @if (!string.IsNullOrEmpty(query))
                {
                    <a asp-action="Users" asp-route-type="@typeFilter" class="btn btn-outline-secondary"
                       data-testid="users-search-clear">Clear</a>
                }
            </div>

            <div class="btn-group" role="group" aria-label="Filter by user type" data-testid="users-type-filter">
                <a asp-action="Users" asp-route-q="@query" asp-route-type="all"
                   class="btn btn-sm @(typeFilter == "all" ? "btn-primary" : "btn-outline-primary")"
                   data-testid="users-filter-all">
                    <i class="bi bi-people"></i> All
                </a>
                <a asp-action="Users" asp-route-q="@query" asp-route-type="individual"
                   class="btn btn-sm @(typeFilter == "individual" ? "btn-info text-dark" : "btn-outline-info")"
                   data-testid="users-filter-individual">
                    <i class="bi bi-person"></i> Individuals
                </a>
                <a asp-action="Users" asp-route-q="@query" asp-route-type="clinic"
                   class="btn btn-sm @(typeFilter == "clinic" ? "btn-warning text-dark" : "btn-outline-warning")"
                   data-testid="users-filter-clinic">
                    <i class="bi bi-hospital"></i> Clinics
                </a>
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Type</th>
                        <th class="text-end">Profiles</th>
                        <th>Registered</th>
                        <th>Last login</th>
                        <th class="text-end">Paid bought</th>
                        <th class="text-end">Paid consum.</th>
                        <th class="text-end">Paid left</th>
                        <th class="text-end">Bonus left</th>
                        <th class="text-end">Total paid</th>
                        <th class="text-center">Flags</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="12" class="text-muted text-center py-4">No users found.</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        var u = item.User;
                        var isClinic = string.Equals(u.UserType, "Clinic", StringComparison.OrdinalIgnoreCase);
                        <tr class="@(u.IsBlocked ? "table-danger" : "")" data-testid="admin-users-row">
                            <td class="fw-semibold">@u.Email</td>
                            <td>
                                @if (isClinic)
                                {
                                    <span class="badge bg-warning text-dark" data-testid="user-type-badge"
                                          title="B2B account (Clinic / Lab)">
                                        <i class="bi bi-hospital"></i> Clinic
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(item.ClinicName))
                                    {
                                        <div class="small text-muted mt-1" data-testid="user-clinic-name">
                                            @item.ClinicName
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark" data-testid="user-type-badge"
                                          title="B2C account (Individual)">
                                        <i class="bi bi-person"></i> Individual
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="UserProfiles" asp-route-email="@u.Email"
                                   class="badge bg-light text-dark border text-decoration-none"
                                   data-testid="user-profiles-count"
                                   title="@(isClinic ? "View patients managed by this clinic" : "View family profiles owned by this user")">
                                    <i class="bi @(isClinic ? "bi-people-fill" : "bi-person-lines-fill")"></i>
                                    @item.ProfilesCount
                                </a>
                            </td>
                            <td class="text-nowrap small">@u.DataC.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-nowrap small">@(u.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td class="text-end">@u.Credite</td>
                            <td class="text-end">@u.CreditConsum</td>
                            <td class="text-end fw-semibold">@u.CreditRest</td>
                            <td class="text-end fw-semibold text-warning">@u.BonusCreditsRemaining</td>
                            <td class="text-end fw-semibold">@u.TotalPaid.ToString("F2") €</td>
                            <td class="text-center">
                                @if (u.IsAdmin)
                                {
                                    <span class="badge bg-warning text-dark">admin</span>
                                }
                                @if (u.IsBlocked)
                                {
                                    <span class="badge bg-danger">blocked</span>
                                }
                            </td>
                            <td>
                                <a asp-action="UserDetail" asp-route-email="@u.Email"
                                   class="btn btn-sm btn-outline-primary">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" asp-action="Users"
                           asp-route-q="@query" asp-route-type="@typeFilter" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
