@model MedicalApp.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <h2 class="text-primary fw-bold mb-0">
            <i class="bi bi-shield-lock"></i> Admin Dashboard
        </h2>
        <div class="ms-auto">
            <a asp-action="Users" class="btn btn-outline-primary btn-sm">Users</a>
            <a asp-action="SendEmail" class="btn btn-outline-primary btn-sm">Bulk email</a>
            <a asp-action="PromoCodes" class="btn btn-outline-primary btn-sm">Promo codes</a>
            <a asp-action="TranslationCoverage" class="btn btn-outline-info btn-sm"
               data-testid="btn-translation-coverage"
               title="See translation completeness per language">
                &#127757; Translations
            </a>
            <form asp-action="SendDailySummaryNow" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-success btn-sm"
                        title="Trimite acum rezumatul zilnic catre toti adminii"
                        data-testid="send-daily-summary-now-btn">
                    &#128231; Send daily summary now
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @* ===== LOINC microservice health widget (admin-only, polls every 30s) ===== *@
    <div class="card mb-3 border-0 shadow-sm" data-testid="loinc-health-widget">
        <div class="card-body py-2 px-3">
            <div class="d-flex align-items-center flex-wrap gap-2">
                <strong class="me-1" style="font-size:.9rem;">
                    <i class="bi bi-cpu"></i> LOINC microservice (Python)
                </strong>
                <span id="loincHealthDot" data-testid="loinc-health-dot"
                      class="rounded-circle bg-secondary"
                      style="width:11px;height:11px;display:inline-block;"
                      title="Se verifică..."></span>
                <span id="loincHealthStatus" data-testid="loinc-health-status"
                      class="badge bg-secondary text-uppercase" style="letter-spacing:.04em;font-size:.7rem;">
                    Verific…
                </span>
                <span id="loincHealthDetails" data-testid="loinc-health-details"
                      class="small text-muted ms-1"></span>
                <span class="ms-auto small text-muted" id="loincHealthLastChecked"
                      data-testid="loinc-health-last-checked"></span>
                <button type="button" id="loincHealthRefresh" data-testid="loinc-health-refresh"
                        class="btn btn-outline-secondary btn-sm py-0 px-2" title="Verifică din nou">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
    </div>
    @* Inline script — intentionally NOT in @section Scripts so we don't collide
       with an existing Scripts section already defined further down in this view. *@
    <script>
    (function(){
        // Polls /Admin/LoincServiceHealth every 30s and updates the dot + badge.
        // Runs ONLY on the Admin page — has zero impact on user-facing pages.
        var url = '@Url.Action("LoincServiceHealth", "Admin")';
        var dot     = document.getElementById('loincHealthDot');
        var badge   = document.getElementById('loincHealthStatus');
        var details = document.getElementById('loincHealthDetails');
        var stamp   = document.getElementById('loincHealthLastChecked');
        var refresh = document.getElementById('loincHealthRefresh');
        if (!dot || !badge) return;

        function apply(state) {
            var bg = 'bg-secondary', label = 'Necunoscut';
            if (state === 'ok')            { bg = 'bg-success'; label = 'Online'; }
            else if (state === 'down')     { bg = 'bg-danger';  label = 'Oprit'; }
            else if (state === 'timeout')  { bg = 'bg-warning text-dark'; label = 'Timeout'; }
            else if (state === 'error')    { bg = 'bg-danger';  label = 'Eroare'; }
            else if (state === 'disabled') { bg = 'bg-secondary'; label = 'Dezactivat'; }
            else                           { bg = 'bg-secondary'; label = 'Verific…'; }
            dot.className   = 'rounded-circle ' + (state === 'ok' ? 'bg-success' :
                                                   state === 'timeout' ? 'bg-warning' :
                                                   (state === 'down' || state === 'error') ? 'bg-danger' : 'bg-secondary');
            badge.className = 'badge text-uppercase ' + bg;
            badge.style.letterSpacing = '.04em';
            badge.style.fontSize = '.7rem';
            badge.textContent = label;
        }

        async function poll() {
            apply('checking');
            try {
                var r = await fetch(url, { headers: { 'Accept': 'application/json' }, cache: 'no-store' });
                var d = await r.json();
                apply(d.status || (d.ok ? 'ok' : 'down'));
                var bits = [];
                if (d.baseUrl)    bits.push(d.baseUrl);
                if (d.loincCount) bits.push(d.loincCount.toLocaleString() + ' coduri LOINC');
                if (d.latencyMs != null) bits.push(d.latencyMs + ' ms');
                if (d.message && !d.ok) bits.push(d.message);
                details.textContent = bits.length ? '· ' + bits.join(' · ') : '';
            } catch (e) {
                apply('error');
                details.textContent = '· ' + (e && e.message ? e.message : 'fetch error');
            }
            if (stamp) stamp.textContent = 'verificat ' + new Date().toLocaleTimeString();
        }

        poll();
        var timer = setInterval(poll, 30000);
        if (refresh) refresh.addEventListener('click', poll);
        document.addEventListener('visibilitychange', function(){
            if (document.hidden) { clearInterval(timer); timer = null; }
            else if (!timer)     { poll(); timer = setInterval(poll, 30000); }
        });
    })();
    </script>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["AdminFlash"] != null)
    {
        <div class="alert alert-info">@TempData["AdminFlash"]</div>
    }

    <!-- STATS CARDS -->
    <div class="row g-3 mb-4">
        @{
            var statCards = new (string Label, string Value, string Color, string Icon)[]
            {
                ("Total users",       Model.TotalUsers.ToString(),             "primary", "bi-people"),
                ("Paying users",      Model.PayingUsers.ToString(),            "success", "bi-credit-card"),
                ("Active users",      Model.ActiveUsers.ToString(),            "info",    "bi-activity"),
                ("New (7 days)",      Model.NewUsersLast7Days.ToString(),      "warning", "bi-person-plus"),
                ("Blocked users",     Model.BlockedUsers.ToString(),           "danger",  "bi-slash-circle"),
                ("Total revenue",     $"{Model.TotalRevenueEur:F2} €",         "success", "bi-cash-stack"),
                ("Revenue 30d",       $"{Model.RevenueLast30DaysEur:F2} €",    "success", "bi-graph-up"),
                ("Purchases 30d",     Model.PurchasesLast30Days.ToString(),    "primary", "bi-bag-check"),
                ("Paid credits bought",   Model.TotalCreditsPurchased.ToString(),  "primary", "bi-coin"),
                ("Paid credits consumed", Model.TotalCreditsConsumed.ToString(),   "secondary","bi-fire"),
                ("Paid credits remaining",Model.TotalCreditsRemaining.ToString(),  "info",    "bi-wallet2"),
                ("Bonus granted",     Model.TotalBonusGranted.ToString(),      "warning", "bi-gift"),
                ("Bonus consumed",    Model.TotalBonusConsumed.ToString(),     "secondary","bi-fire"),
                ("Bonus remaining",   Model.TotalBonusRemaining.ToString(),    "warning", "bi-stars"),
                ("Active promo codes",Model.ActivePromoCodes.ToString(),       "warning", "bi-ticket-perforated")
            };
        }
        @foreach (var c in statCards)
        {
            <div class="col-md-3 col-sm-6">
                <div class="card border-start border-@c.Color border-4 shadow-sm h-100">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase fw-semibold">@c.Label</div>
                        <div class="fs-3 fw-bold text-@c.Color">@c.Value</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-3">
        <!-- TOP SPENDERS -->
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white fw-semibold">
                    Top 10 spenders
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Email / Type</th>
                                <th class="text-end">Paid (€)</th>
                                <th class="text-end">Credits bought</th>
                                <th class="text-end">Consumed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.TopSpenders.Any())
                            {
                                <tr><td colspan="4" class="text-muted text-center py-4">No paying users yet.</td></tr>
                            }
                            @foreach (var s in Model.TopSpenders)
                            {
                                var isClinic = string.Equals(s.UserType, "Clinic", StringComparison.OrdinalIgnoreCase);
                                <tr data-testid="top-spender-row">
                                    <td>
                                        <a asp-action="UserDetail" asp-route-email="@s.Email" class="text-decoration-none">
                                            @s.Email
                                        </a>
                                        <div class="mt-1 d-flex align-items-center flex-wrap gap-1">
                                            @if (isClinic)
                                            {
                                                <span class="badge bg-warning text-dark" data-testid="spender-type-badge"
                                                      title="B2B account (Clinic / Lab)">
                                                    <i class="bi bi-hospital"></i> Clinic
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(s.ClinicName))
                                                {
                                                    <span class="small text-muted" data-testid="spender-clinic-name">
                                                        @s.ClinicName
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark" data-testid="spender-type-badge"
                                                      title="B2C account (Individual)">
                                                    <i class="bi bi-person"></i> Individual
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold">@s.TotalPaid.ToString("F2")</td>
                                    <td class="text-end">@s.Credite</td>
                                    <td class="text-end">@s.CreditConsum</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- REVENUE CHART 30 DAYS -->
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white fw-semibold">
                    Revenue last 30 days
                </div>
                <div class="card-body">
                    <canvas id="revenueChart" height="120"
                            data-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueChart.Select(r => r.Date.ToString("dd/MM"))))'
                            data-values='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueChart.Select(r => r.Amount)))'></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================================ -->
    <!-- AI USAGE WIDGET — Gemini Flash vs Pro split, last 30 days     -->
    <!-- ============================================================ -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm" data-testid="admin-ai-usage-card">
                <div class="card-header bg-info text-white fw-semibold d-flex align-items-center flex-wrap gap-2">
                    <span>&#129302; AI usage (Gemini) &mdash; last 30 days</span>
                    <span class="ms-auto small">
                        Total est. cost:
                        <strong data-testid="admin-ai-total-cost">$@Model.AiCost30DaysUsd.ToString("F2")</strong>
                        &nbsp;&middot;&nbsp; Fallback to Pro:
                        <strong data-testid="admin-ai-fallback-pct">@Model.AiFallbackRatioPct.ToString("F1")%</strong>
                    </span>
                    <button type="button" class="btn btn-sm btn-outline-light"
                            data-bs-toggle="modal" data-bs-target="#resetAiUsageModal"
                            data-testid="btn-open-reset-ai-usage"
                            title="Reset all AI usage counters">
                        &#x21BA; Reset
                    </button>
                </div>
                <div class="card-body">
                    @{
                        var noB2c = !Model.AiUsageB2C.Rows.Any();
                        var noCam = !Model.AiUsageCam.Rows.Any();
                    }
                    @if (noB2c && noCam)
                    {
                        <p class="text-muted mb-0">
                            No Gemini calls were recorded in the last 30 days
                            (or the counters were just reset).
                        </p>
                    }
                    else
                    {
                        <div class="row g-4">
                            @{
                                // Local helper-style values reused for each column.
                                // Defined as a tiny inline tuple list so the markup
                                // stays DRY without spawning a partial view.
                                var columns = new[] {
                                    new { Title = "B2C — Individual users",
                                          Icon  = "&#128104;",
                                          CanvasId = "aiUsageChartB2C",
                                          TestIdPrefix = "admin-ai-b2c",
                                          Data = Model.AiUsageB2C },
                                    new { Title = "CAM — Clinics (batch)",
                                          Icon  = "&#127973;",
                                          CanvasId = "aiUsageChartCAM",
                                          TestIdPrefix = "admin-ai-cam",
                                          Data = Model.AiUsageCam },
                                };
                            }

                            @foreach (var col in columns)
                            {
                                <div class="col-lg-6">
                                    <div class="border rounded p-3 h-100 bg-light-subtle">
                                        <div class="d-flex align-items-center mb-3 flex-wrap gap-2">
                                            <h6 class="mb-0 fw-bold">@Html.Raw(col.Icon) @col.Title</h6>
                                            <span class="ms-auto small text-muted">
                                                <strong data-testid="@(col.TestIdPrefix)-total-calls">@col.Data.TotalCalls</strong> calls
                                                &middot; cost
                                                <strong data-testid="@(col.TestIdPrefix)-total-cost">$@col.Data.TotalCostUsd.ToString("F2")</strong>
                                                <span class="badge bg-secondary ms-1"
                                                      data-testid="@(col.TestIdPrefix)-share-pct">
                                                    @col.Data.ShareOfCombinedPct.ToString("F0")% of total
                                                </span>
                                            </span>
                                        </div>

                                        @if (!col.Data.Rows.Any())
                                        {
                                            <p class="text-muted small mb-3" data-testid="@(col.TestIdPrefix)-empty">
                                                No calls from this source in the last 30 days.
                                            </p>
                                        }
                                        else
                                        {
                                            <!-- Compact per-model rows -->
                                            <div class="row g-2 mb-3">
                                                @foreach (var u in col.Data.Rows)
                                                {
                                                    <div class="col-12">
                                                        <div class="border rounded p-2 bg-white"
                                                             data-testid="@(col.TestIdPrefix)-row-@u.ShortName">
                                                            <div class="d-flex align-items-center mb-1">
                                                                <span class="badge @u.BadgeClass">@u.ShortName</span>
                                                                <small class="text-muted ms-2">@u.ModelId</small>
                                                                <span class="ms-auto small fw-semibold">$@u.EstimatedCostUsd.ToString("F2")</span>
                                                            </div>
                                                            <div class="d-flex flex-wrap gap-3 small text-muted">
                                                                <span>Calls: <strong class="text-dark">@u.Count</strong></span>
                                                                <span>In: @u.InputTokens.ToString("N0")</span>
                                                                <span>Out: @u.OutputTokens.ToString("N0")</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            <!-- Doughnut chart (one per column). Wrapper limits width so the
                                                 chart stays compact (~50% of the previous size). The data-*
                                                 attrs are consumed by the script at the bottom of this view. -->
                                            <div class="mx-auto" style="max-width: 220px;">
                                                <canvas id="@col.CanvasId" height="160"
                                                        data-testid="@(col.TestIdPrefix)-chart"
                                                        data-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(col.Data.Rows.Select(u => u.ShortName + " (" + u.ModelId + ")")))'
                                                        data-counts='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(col.Data.Rows.Select(u => u.Count)))'
                                                        data-colors='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(col.Data.Rows.Select(u => u.ShortName == "Flash" ? "#198754" : u.ShortName == "Pro" ? "#ffc107" : "#6c757d")))'></canvas>
                                            </div>

                                            <p class="small text-muted mb-0 mt-2">
                                                Pro fallback share: <strong>@col.Data.FallbackRatioPct.ToString("F1")%</strong>
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <p class="small text-muted mt-3 mb-0">
                            Both charts read from <code>AiUsageLogs</code>. Use the
                            &#x21BA; <em>Reset</em> button in the header to clear all
                            counters &mdash; user history is not affected.
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@* ================================================================
   RELIABILITY WIDGET — per-model error rate (last 30 days)
   Shows the admin which Gemini model is hiccuping so they can swap
   Model/FallbackModel in appsettings.json before users notice. Reads
   the same AiUsageLogs table — independent of cost, captures ALL
   token-consuming calls including errors and rejections.
   ================================================================ *@
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm" data-testid="admin-ai-reliability-card">
            <div class="card-header bg-secondary text-white fw-semibold d-flex align-items-center flex-wrap gap-2">
                <span>&#128737; Reliability &mdash; Gemini error rates (last 30 days)</span>
                <span class="ms-auto small text-white-50">
                    Watch this when users report intermittent failures.
                </span>
            </div>
            <div class="card-body">
                @if (!Model.ErrorRates.Any())
                {
                    <p class="text-muted mb-0">
                        No Gemini calls were recorded in the last 30 days.
                    </p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0" data-testid="admin-ai-reliability-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Model</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end text-success">Success</th>
                                    <th class="text-end text-danger">Errors</th>
                                    <th class="text-end text-muted">Rejected</th>
                                    <th class="text-end" style="min-width:180px;">Error rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.ErrorRates)
                                {
                                    <tr data-testid="admin-ai-reliability-row-@r.ShortName">
                                        <td>
                                            <span class="badge bg-@(r.ShortName == "Flash" ? "success" : r.ShortName == "Pro" ? "warning text-dark" : "secondary")">@r.ShortName</span>
                                            <small class="text-muted ms-2">@r.ModelId</small>
                                        </td>
                                        <td class="text-end"><strong>@r.Total</strong></td>
                                        <td class="text-end">@r.Success</td>
                                        <td class="text-end @(r.Errors > 0 ? "text-danger fw-bold" : "")">@r.Errors</td>
                                        <td class="text-end text-muted">@r.Rejected</td>
                                        <td class="text-end" style="min-width:180px;">
                                            <div class="d-flex align-items-center gap-2 justify-content-end">
                                                <div class="progress flex-grow-1" style="height: 8px; max-width: 110px;">
                                                    <div class="progress-bar bg-@r.BadgeColor"
                                                         role="progressbar"
                                                         style="width: @(Math.Min(100, Math.Max(2, r.ErrorRatePct)))%;"
                                                         aria-valuenow="@r.ErrorRatePct"
                                                         aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <span class="badge bg-@r.BadgeColor"
                                                      data-testid="admin-ai-reliability-pct-@r.ShortName">
                                                    @r.ErrorRatePct.ToString("F1")%
                                                </span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <p class="small text-muted mt-3 mb-2">
                        Thresholds: <span class="badge bg-success">&lt; 5%</span> healthy,
                        <span class="badge bg-warning text-dark">5&ndash;15%</span> watch,
                        <span class="badge bg-danger">&gt; 15%</span> swap primary model.
                    </p>

                    @if (Model.RecentErrors.Any())
                    {
                        <details class="mt-3" data-testid="admin-ai-recent-errors">
                            <summary class="small fw-semibold text-muted" style="cursor:pointer;">
                                &#128269; Show last 5 error messages
                            </summary>
                            <ul class="list-group list-group-flush mt-2 small">
                                @foreach (var e in Model.RecentErrors)
                                {
                                    <li class="list-group-item px-0 py-2">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="badge bg-light text-dark border">@e.Source</span>
                                            <code class="small text-muted">@e.ModelId</code>
                                            <span class="ms-auto text-muted">@e.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</span>
                                        </div>
                                        <div class="text-danger" style="font-family: ui-monospace, monospace; word-break: break-word;">
                                            @(e.Message.Length > 220 ? e.Message.Substring(0, 220) + "…" : e.Message)
                                        </div>
                                    </li>
                                }
                            </ul>
                        </details>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Reset AI usage counters confirmation modal.
     Submits to AdminController.ResetAiUsage which wipes the AiUsageLogs
     table only (InterpretationHistories untouched, so user-facing history
     is preserved). -->
<div class="modal fade" id="resetAiUsageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    &#9888;&#65039; Reset AI usage counters
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">
                    This will permanently delete <strong>all rows</strong> from
                    <code>AiUsageLogs</code> (Gemini call counters, tokens,
                    estimated costs for the last 30 days).
                </p>
                <p class="small text-muted mb-0">
                    User-facing data (interpretation history, clinic batches,
                    purchases) is <strong>NOT affected</strong>. After reset, the
                    "AI usage" widget starts counting again from zero.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                        data-testid="btn-cancel-reset-ai-usage">
                    Cancel
                </button>
                <form asp-controller="Admin" asp-action="ResetAiUsage" method="post" class="d-inline m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger" data-testid="btn-confirm-reset-ai-usage">
                        &#x21BA; Yes, reset counters
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var ctx = document.getElementById('revenueChart');
            if (!ctx) return;
            var labels = JSON.parse(ctx.dataset.labels || '[]');
            var data = JSON.parse(ctx.dataset.values || '[]');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'EUR',
                        data: data,
                        backgroundColor: 'rgba(40, 167, 69, 0.6)',
                        borderColor: 'rgba(40, 167, 69, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        })();
    </script>

    <!-- AI usage doughnuts: one per Source (B2C / CAM). Both canvases read
         their data from data-* attrs, so this script is a tiny generic loop. -->
    <script>
        (function () {
            var canvases = document.querySelectorAll('canvas#aiUsageChartB2C, canvas#aiUsageChartCAM');
            canvases.forEach(function (aiCtx) {
                var aiLabels = JSON.parse(aiCtx.dataset.labels || '[]');
                var aiCounts = JSON.parse(aiCtx.dataset.counts || '[]');
                var aiColors = JSON.parse(aiCtx.dataset.colors || '[]');
                if (aiLabels.length === 0) return;
                new Chart(aiCtx, {
                    type: 'doughnut',
                    data: {
                        labels: aiLabels,
                        datasets: [{
                            data: aiCounts,
                            backgroundColor: aiColors,
                            borderWidth: 1,
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom' },
                            tooltip: {
                                callbacks: {
                                    label: function (item) {
                                        var total = item.dataset.data.reduce(function (a, b) { return a + b; }, 0);
                                        var pct = total > 0 ? (100 * item.parsed / total).toFixed(1) : "0.0";
                                        return item.label + ': ' + item.parsed + ' (' + pct + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            });
        })();
    </script>
}
