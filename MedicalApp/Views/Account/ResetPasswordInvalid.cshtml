@{
    ViewData["Title"] = Loc.T("ResetPasswordTitle");
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h3 class="text-danger mb-3">@Loc.T("InvalidOrExpiredToken")</h3>
                    <p class="text-muted">@Loc.T("InvalidOrExpiredTokenIntro")</p>

                    <a asp-controller="Account" asp-action="ForgotPassword" class="btn btn-primary mt-2">
                        @Loc.T("RequestNewLink")
                    </a>
                    <div class="mt-3">
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none small">
                            &larr; @Loc.T("BackToLogin")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
